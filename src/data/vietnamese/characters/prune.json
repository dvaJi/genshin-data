  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "Phán Quyết Truy Cứu",
      "description": "Trong Kỹ Năng Nộ <color=#FFD780FF><b>Chuông Reo - Thời Khắc Săn Ma</b></color>, sau khi Chuông Nhử Phù Thủy ở chế độ \"Săn Lùng\" gây sát thương lên kẻ địch, nếu lần sát thương này kích hoạt phản ứng Khuếch Tán, sẽ triệu hồi một <b><span style=\"color:#FFD780FF\">Búa Săn Tai Ương</span></b> được chuyển hóa nguyên tố theo phản ứng Khuếch Tán lần này ở trước mặt kẻ địch và đập xuống, gây Sát Thương Nguyên Tố tương ứng bằng 150% Tấn Công của Prune. Sát thương này được xem là sát thương Kỹ Năng Nộ.",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "Tiếng Chuông Cộng Hưởng",
      "description": "Sau khi Prune dùng <b><span style=\"color:#FFD780FF\">Búa Săn Tai Ương</span></b> đã chuyển hóa nguyên tố đánh trúng kẻ địch, các nhân vật khác trong đội ở gần sẽ nhận được hiệu quả Tiếng Chuông Khích Lệ kéo dài 5s: Khi Tấn Công Thường, Trọng Kích, Tấn Công Khi Đáp, Kỹ Năng Nguyên Tố hoặc Kỹ Năng Nộ gây sát thương lên kẻ địch, dựa trên phần Tấn Công vượt quá 2000 của Prune khi họ nhận hiệu quả Tiếng Chuông Khích Lệ, sẽ tăng sát thương gây ra của lần tấn công này: Mỗi điểm Tấn Công sẽ tăng 0.025% sát thương gây ra bởi lần tấn công này, tối đa tăng 50%.",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "Cải Tạo! Gõ Gõ Gõ!",
      "description": "Khi ghép nguyên liệu thiên phú nhân vật, có tỷ lệ 10% sản sinh thêm 1 nguyên liệu thiên phú ngẫu nhiên khác của cùng khu vực, cấp bậc giống với nguyên liệu nhận được sau khi ghép.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "Lời Thề Giải Cứu, Hành Trình Bắt Đầu Từ Đây",
      "description": "Sau khi đòn tấn công của <b><span style=\"color:#FFD780FF\">Búa Săn Tai Ương</span></b> đã chuyển hóa nguyên tố đánh trúng kẻ địch, sẽ hồi phục 2 điểm Năng Lượng Nguyên Tố cho Prune. Hiệu quả này mỗi 1.8s tối đa kích hoạt một lần.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "Xếp Gọn Hành Trang, Sức Mạnh Nguyên Tố Diệu Kỳ",
      "description": "Trong Kỹ Năng Nộ <color=#FFD780FF><b>Chuông Reo - Thời Khắc Săn Ma</b></color>, khi Chuông Nhử Phù Thủy đang ở chế độ \"Săn Lùng\", Prune sẽ nhận thêm hiệu quả \"Săn Lùng Ma Nữ\": Tấn Công của Prune tăng 10%. Khi Chuông Nhử Phù Thủy và <b><span style=\"color:#FFD780FF\">Búa Săn Tai Ương</span></b> đã chuyển hóa nguyên tố đánh trúng kẻ địch, Tấn Công sẽ tiếp tục tăng thêm 5%. Thông qua cách thức trên, tối đa tăng Tấn Công đến 40%.<br/>Trong thời gian duy trì hiệu quả, nếu thi triển lại Chuông Reo - Thời Khắc Săn Ma, sẽ xóa bỏ hiệu quả nêu trên.",
      "level": 2
    },
    {
      "_id": 1323,
      "id": "the_caravan_exits_the_mountain_pass_the_scenery_once_more_changed",
      "name": "Thương Đội Vượt Núi, Cảnh Sắc Trước Mắt Đổi Thay",
      "description": "Cấp kỹ năng <color=#FFD780FF><b>Chuông Reo - Thời Khắc Săn Ma</b></color> +3.<br/>Tăng tối đa đến cấp 15.",
      "level": 3
    },
    {
      "_id": 1324,
      "id": "looking_back_following_the_wind_ones_shadow_still_halved",
      "name": "Ngoảnh Đầu Theo Gió, Bóng Hình Chỉ Còn Một Nửa",
      "description": "Sau khi <b><span style=\"color:#FFD780FF\">Búa Săn Tai Ương</span></b> đã chuyển hóa nguyên tố đánh trúng kẻ địch, sẽ nảy lên một lần nữa và rơi xuống vị trí kẻ địch ở gần, gây Sát Thương Nguyên Tố tương ứng bằng 80% Tấn Công lên kẻ địch trúng đòn.",
      "level": 4
    },
    {
      "_id": 1325,
      "id": "100_defeats_no_problem_tomorrow_we_go_again",
