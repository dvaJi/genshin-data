  "passives": [
    {
      "id": "field_observation_notes",
      "name": "Sổ Tay Quan Sát Vùng Hoang Dã",
      "description": "Khi Lumi trong trận, kẻ địch xung quanh Lumi sẽ giảm 15% <span style=\"color:#FFE699FF\">Kháng Nguyên Tố Nham</span>.<br/><br/><span style=\"color:#FFD780FF\">Nguyệt Triệu - Rực Sáng</span>: Kỹ Năng Nguyên Tố <color=#FFD780FF><b>Đối Sách - Lumi Xung Trận!</b></color> và Kỹ Năng Nộ <color=#FFD780FF><b>Ghi Chú - Sinh Tồn Trong Tuyệt Cảnh</b></color> của Linnea sẽ được cường hóa. Sau khi triệu hồi Lumi ra trận, kẻ địch xung quanh Lumi sẽ giảm thêm 15% <span style=\"color:#FFE699FF\">Kháng Nguyên Tố Nham</span>.",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "Cẩm Nang Khoa Học Tự Nhiên Muôn Loài",
      "description": "Căn cứ vào nhân vật ra trận hiện tại trong đội bản thân, Linnea sẽ tăng Tinh Thông Nguyên Tố cho nhân vật chỉ định trong đội, mức tăng dựa trên 5% Phòng Ngự của Linnea. Nếu nhân vật ra trận hiện tại trong đội bản thân:<br/>·Là nhân vật Nguyệt Triệu: Tăng Tinh Thông Nguyên Tố cho nhân vật này.<br/>·Không phải nhân vật Nguyệt Triệu: Tăng Tinh Thông Nguyên Tố cho bản thân Linnea.",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "Chúc Phúc Nguyệt Triệu - Khảo Sát Môi Trường Sống",
      "description": "Khi nhân vật trong đội kích hoạt phản ứng Kết Tinh Nguyên Tố Thủy, sẽ chuyển thành phản ứng Nguyệt-Kết Tinh, đồng thời tăng sát thương cơ bản của phản ứng Nguyệt-Kết Tinh nhân vật trong đội gây ra dựa trên Phòng Ngự của Linnea: Mỗi 100 điểm Phòng Ngự sẽ tăng 0.7% sát thương cơ bản của phản ứng Nguyệt-Kết Tinh, tối đa tăng 14% sát thương theo cách này.<br/><br/>Ngoài ra, khi Linnea trong đội, <span style=\"color:#FFD780FF\">Nguyệt Triệu</span> của đội sẽ tăng 1 cấp.",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "Nhà Mạo Hiểm Bậc Thầy",
      "description": "Khi không trong trạng thái chiến đấu, Linnea thực hiện <span style=\"color:#FFD780FF\">ngắm bắn</span> sẽ giảm mạnh thời gian tụ lực, đồng thời chuyển sang bắn <span style=\"color:#FFD780FF\">Mũi Tên Siêu Tiện Lợi</span> đặc biệt, căn cứ vào mục tiêu bị bắn trúng để sản sinh hiệu quả khác nhau. Nếu mục tiêu bị bắn trúng là:<br/>·Động vật nhất định: <span style=\"color:#FFD780FF\">Mũi Tên Siêu Tiện Lợi</span> sẽ chuyển hóa thành \"Lưới\" đặc thù, có thể bắt được thần hình của động vật, lấy đó làm trung gian và biến ra hình dạng của động vật nhỏ. Số lần dùng \"Lưới\" mỗi tuần sẽ có giới hạn.<br/>·Khoáng vật dùng để chế tạo: Linnea sẽ cử Lumi đến nhanh chóng phá hủy khoáng vật bị <span style=\"color:#FFD780FF\">Mũi Tên Siêu Tiện Lợi</span> đánh dấu, đồng thời thu thập khoáng thạch rơi ra. Nếu Lumi không trong trận, sẽ triệu hồi Lumi trong giây lát để giúp đỡ Linnea thu thập khoáng thạch.<br/><br/>Sát thương <span style=\"color:#FFD780FF\">Mũi Tên Siêu Tiện Lợi</span> gây ra cho kẻ địch sẽ giảm còn 20% sát thương gốc. Ngoài ra, sau khi bắn một lượng nhất định <span style=\"color:#FFD780FF\">Mũi Tên Siêu Tiện Lợi</span> trong thời gian ngắn, Linnea cần nghỉ ngơi trong giây lát mới có thể bắn tiếp.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1301,
      "id": "provisional_classification",
      "name": "Phân Loại Chưa Hoàn Thiện",
      "description": "Khi thi triển Kỹ Năng Nguyên Tố <color=#FFD780FF><b>Đối Sách - Lumi Xung Trận!</b></color>, hoặc khi kích hoạt Trăng Trôi Hòa Tấu, Linnea sẽ nhận được 6 tầng hiệu quả <span style=\"color:#FFD780FF\">Biên Tập Trải Nghiệm</span>, hiệu quả này duy trì 10s, tối đa cộng dồn 18 tầng. Khi nhân vật trong đội ở gần gây sát thương phản ứng Nguyệt-Kết Tinh, sẽ tiêu hao một tầng Biên Tập Trải Nghiệm để tăng sát thương gây ra, mức tăng tương đương 75% Phòng Ngự của Linnea.<br/>Ngoài ra, khi Lumi dùng <span style=\"color:#FFD780FF\">Búa Nặng Triệu Tấn</span> trong <color=#FFD780FF><b>Hình Thái Tối Thượng</b></color>, Linnea có thể tiêu hao tối đa 5 tầng Biên Tập Trải Nghiệm, mỗi tầng sẽ tăng sát thương gây ra tương đương 150% Phòng Ngự của Linnea.",
      "level": 1
    },
    {
      "_id": 1302,
      "id": "tidings_of_joy_and_sorrow",
      "name": "Chỉ Dụ Vui Và Buồn",
      "description": "Trong 8s sau khi kích hoạt Trăng Trôi Hòa Tấu, tất cả nhân vật nguyên tố <span style=\"color:#80C0FFFF\">Thủy</span> và <span style=\"color:#FFE699FF\">Nham</span> trong đội sẽ tăng 40% Sát Thương Bạo Kích, đồng thời Lumi dùng <span style=\"color:#FFD780FF\">Búa Nặng Triệu Tấn</span> trong <color=#FFD780FF><b>Hình Thái Tối Thượng</b></color> sẽ tăng thêm 150% Sát Thương Bạo Kích.<br/><br/><span style=\"color:#FFD780FF\">Nguyệt Triệu - Rực Sáng</span>: Khi Lumi dùng <span style=\"color:#FFD780FF\">Búa Nặng Cường Lực</span> trong <color=#FFD780FF><b>Hình Thái Đáng Gờm</b></color>, hoặc khi dùng <span style=\"color:#FFD780FF\">Búa Nặng Triệu Tấn</span> trong Hình Thái Tối Thượng, sẽ kích hoạt một lần Trăng Trôi Hòa Tấu và Trăng Trôi Hòa Tấu lần này sẽ xem như tất cả nhân vật nguyên tố <span style=\"color:#80C0FFFF\">Thủy</span> và <span style=\"color:#FFE699FF\">Nham</span> trong đội đều gán ấn nguyên tố trong phản ứng.",
      "level": 2
