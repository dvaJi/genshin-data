  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "曉風的行軍",
      "description": "隊伍中存在<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色時，按照上述元素類型的優先順序，基於法爾伽的攻擊力，每1000點攻擊力都將使法爾伽獲得10%<span style=\"color:#80FFD7FF\">風元素傷害加成</span>與對應元素傷害加成（上述元素類型中，至多有一種元素類型可以依此方式獲得傷害加成），至多依此方式獲得25%。<br/><br/>此外，如果隊伍中存在至少2名<span style=\"color:#80FFD7FF\">風元素</span>角色，或存在至少2名元素類型相同的<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色，法爾伽在<b><span style=\"color:#FFD780FF\">狂飆突進</span></b>模式下進行的普通攻擊、重擊、特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>與施放的特殊元素戰技<b><span style=\"color:#FFD780FF\">四風將起</span></b>將造成原本140%的傷害。若隊伍中同時存在至少2名<span style=\"color:#80FFD7FF\">風元素</span>角色與至少2名元素類型相同的<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色，則會使上述效果提升至220%。",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "風幟的先引",
      "description": "隊伍中附近的角色觸發擴散反應時，法爾伽將獲得一層<span style=\"color:#FFD780FF\">「蒼牙之誓」</span>，使法爾伽的普通攻擊、重擊、特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>與施放的特殊元素戰技<b><span style=\"color:#FFD780FF\">四風將起</span></b>造成的傷害提升7.5%。該效果持續8秒，至多疊加4層，每名角色每1秒至多依此方式使法爾伽獲得一層<span style=\"color:#FFD780FF\">「蒼牙之誓」</span>。",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "歸風的凱歌",
      "description": "隊伍中每有一名蒙德角色，透過長按施放的元素戰技<span style=\"color:#FFD780FF\">烈風終墜</span>的冷卻時間就會縮短5%。<br/>該效果在秘境、征討領域、深境螺旋中無效。",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "「來吧，朋友，讓我們在月下共舞」",
      "description": "法爾伽切換至<b><span style=\"color:#FFD780FF\">狂飆突進</span></b>模式時，將額外獲得一次特殊元素戰技<b><span style=\"color:#FFD780FF\">四風將起</span></b>的可用次數。<br/>此外，切換至<span style=\"color:#FFD780FF\">狂飆突進</span>模式後，法爾伽將獲得<span style=\"color:#FFD780FF\">「歌中的佳釀」</span>效果：施放特殊元素戰技<span style=\"color:#FFD780FF\">四風將起</span>時，或進行特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>時，將消耗該效果，使<span style=\"color:#FFD780FF\">四風將起</span>或<span style=\"color:#FFD780FF\">蒼噬</span>造成原本200%的傷害。",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "「待天光破曉，我們便要踏上征途」",
      "description": "施放特殊元素戰技<b><span style=\"color:#FFD780FF\">四風將起</span></b>時，或進行特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>時，法爾伽將會進行一次額外攻擊，造成800%攻擊力的<span style=\"color:#80FFD7FF\">風元素範圍傷害</span>。",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "「朋友，莫要再飲令人落淚的苦酒」",
      "description": "元素戰技<color=#FFD780FF><b>烈風終墜</b></color>的技能等級提高3級。<br/>至多提升至15級。",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "「因為無人能奪去我們歌唱的自由」",
      "description": "法爾伽觸發擴散反應時，依據參與反應的元素類型，使隊伍中附近的所有角色分別獲得20%<span style=\"color:#80FFD7FF\">風元素傷害加成</span>與對應元素傷害加成，持續10秒。",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
      "name": "「斟滿杯中佳釀吧，暴君來了又去」",
      "description": "元素爆發<color=#FFD780FF><b>我即朔風</b></color>的技能等級提高3級。<br/>至多提升至15級。",
      "level": 5
    },
    {
      "_id": 1286,
      "id": "beloved_mondstadt_steadfast_you_shall_shine",
      "name": "「我心愛的蒙德呀，依然屹立如初」",
      "description": "<b><span style=\"color:#FFD780FF\">狂飆突進</span></b>模式獲得強化：<br/>·施放特殊元素戰技<b><span style=\"color:#FFD780FF\">四風將起</span></b>後的短暫時間內，法爾伽可以點按元素戰技或長按普通攻擊，不消耗四風將起的可用次數，進行一次額外的特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>。<br/>·進行特殊重擊<span style=\"color:#FFD780FF\">蒼噬</span>後的短暫時間內，法爾伽可以點按元素戰技，不消耗四風將起的可用次數，施放一次額外的<span style=\"color:#FFD780FF\">四風將起</span>。<br/>透過上述方式進行額外的特殊重擊蒼噬或施放額外的特殊元素戰技四風將起時，無法觸發上述效果。<br/><br/>此外，突破天賦<color=#FFD780FF><b>「風幟的先引」</b></color>中<span style=\"color:#FFD780FF\">「蒼牙之誓」</span>的效果獲得強化：每層<span style=\"color:#FFD780FF\">「蒼牙之誓」</span>還會使法爾伽的暴擊傷害提升20%。",
      "level": 6
    }
  ],
