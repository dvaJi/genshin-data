  "passives": [
    {
      "id": "field_observation_notes",
      "name": "野外觀察手記",
      "description": "露米在場上時，露米附近敵人的<span style=\"color:#FFE699FF\">岩元素抗性</span>會降低15%。<br/><br/><span style=\"color:#FFD780FF\">月兆·滿輝</span>：莉奈婭的元素戰技<color=#FFD780FF><b>對策·露米呀吼吼！</b></color>和元素爆發<color=#FFD780FF><b>備忘·絕境生存指南</b></color>獲得強化，呼喚露米上場後，露米附近敵人的<span style=\"color:#FFE699FF\">岩元素抗性</span>還會進一步降低15%。",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "萬類博物圖鑑",
      "description": "依據隊伍中自己的目前場上角色，莉奈婭會提升隊伍中特定角色的元素精通，提升值基於莉奈婭防禦力的5%。若隊伍中自己的目前場上角色：<br/>·為月兆角色：提升該角色的元素精通。<br/>·不為月兆角色：提升莉奈婭自己的元素精通。",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "月兆祝賜·棲地考察",
      "description": "隊伍中的角色觸發水元素結晶反應時，將轉為觸發月結晶反應，且基於莉奈婭的防禦力，提升隊伍中角色造成的月結晶反應的基礎傷害：每100點防禦力都將提升0.7%月結晶反應的基礎傷害，至多依此方式提升14%傷害。<br/><br/>此外，莉奈婭在隊伍中時，隊伍的<span style=\"color:#FFD780FF\">月兆</span>將會上升一級。",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "大師級的冒險者",
      "description": "不處於戰鬥狀態下時，莉奈婭進行<span style=\"color:#FFD780FF\">瞄準射擊</span>所需的蓄力時間大幅減少，並會轉為射出特製的<span style=\"color:#FFD780FF\">超便利快捷矢</span>，依據命中的目標，產生不同的效果。若命中的目標為：<br/>·特定動物：<span style=\"color:#FFD780FF\">超便利快捷矢</span>會轉化為特殊的「網」，可以拘出小動物的神形，並以其為媒介，再次化出小動物的形體。每週可使用的「網」數量有限。<br/>·鍛造用礦石的礦脈：莉奈婭會派出露米，快速破壞被<span style=\"color:#FFD780FF\">超便利快捷矢</span>標記的礦體，並收集掉落的礦石。若露米不在場上，則會短暫呼喚出露米，幫助莉奈婭獲得礦石。<br/><br/><span style=\"color:#FFD780FF\">超便利快捷矢</span>對敵人造成的傷害降低為原本的20%。此外，短時間內發射一定數量的<span style=\"color:#FFD780FF\">超便利快捷矢</span>後，莉奈婭需要進行短暫的休息，才能繼續發射。",
      "level": 0
    }
  ],
