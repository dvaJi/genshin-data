  "passives": [
    {
      "id": "methexis",
      "name": "分有",
      "description": "施放元素戰技<color=#FFD780FF><b>聖言默示·未現之光</b></color>後的20秒內，尼可將持續「觀測」隊伍中自己的目前場上其他角色。受觀測的角色持續處於場上3秒後，其擁有的<b><span style=\"color:#FFD780FF\">虛己之賜</span></b>效果將會升變為<b><span style=\"color:#FFD780FF\">聖祝之引</span></b>，使其額外提升300點攻擊力。若受觀測的角色為魔導角色，則<span style=\"color:#FFD780FF\">虛己之賜</span>效果將會直接升變為<span style=\"color:#FFD780FF\">聖祝之引</span>。<br/>除尼可外，其他角色擁有的<span style=\"color:#FFD780FF\">聖祝之引</span>將在退場時還原為<span style=\"color:#FFD780FF\">虛己之賜</span>。",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "慕善",
      "description": "隊伍中附近的目前場上角色的元素傷害命中敵人後，尼可自己擁有的<b><span style=\"color:#FFD780FF\">虛己之賜</span></b>將會升變為<b><span style=\"color:#FFD780FF\">聖祝之引</span></b>，持續8秒。",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "靜念",
      "description": "在提瓦特，不處於戰鬥狀態下時，若已獲得目前區域的尋寶羅盤，則尼可的重擊將會轉而施放「御使之引」：呼喚附近的仙靈指引道路，觸發等同於目前區域尋寶羅盤的效果。<br/>該效果有5秒的冷卻時間，且在秘境、征討領域、深境螺旋中無效。",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "「不要懼怕，蒙眷愛的人之子呀」",
      "description": "隊伍中自己的目前場上角色攻擊命中敵人時，將會額外召喚出特殊的「奧跡造影·合一」，對敵人進行協同攻擊，依據該角色的元素類型，造成對應元素範圍傷害，該傷害相當於該角色攻擊力的600%，並視為由該角色造成的傷害。<br/>該效果每6秒至多觸發一次。",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "「我要教導你，指引你應走的路」",
      "description": "元素戰技<color=#FFD780FF><b>聖言默示·未現之光</b></color>的效果獲得強化：<b><span style=\"color:#FFD780FF\">虛己之賜</span></b>還會額外提升300點攻擊力（不計入該效果的攻擊力加成上限），<b><span style=\"color:#FFD780FF\">聖祝之引</span></b>還會依據角色的元素類型，使附近敵人的對應元素抗性降低25%，同元素類型的元素抗性降低效果不能疊加。<br/>此外，尼可施放元素戰技<span style=\"color:#FFD780FF\">聖言默示·未現之光</span>時，也會為附近的目前場上角色賦予熾光護盾。",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "「為你身邊的燈，為你前方的光」",
      "description": "元素戰技<color=#FFD780FF><b>聖言默示·未現之光</b></color>的技能等級提高3級。<br/>至多提升至15級。",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "「向左或向右，無論你行往何方」",
      "description": "隊伍中附近的角色擁有的<b><span style=\"color:#FFD780FF\">虛己之賜</span></b>升變為<b><span style=\"color:#FFD780FF\">聖祝之引</span></b>時，尼可還會為其賦予「先導之佑」效果，持續20秒，每名角色每16秒至多獲得一次該效果。<br/>擁有「先導之佑」的角色的普通攻擊、重擊、下落攻擊、元素戰技與元素爆發造成的傷害提升，提升值相當於尼可攻擊力的70%。該效果將在生效8次或持續時間結束時解除。<br/>同時命中多名敵人時，會依據命中敵人的數量消耗生效次數。隊伍中具有「先導之佑」的角色，其生效次數單獨計算。",
      "level": 4
    },
