  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "裁斷追懲",
      "description": "元素爆發<color=#FFD780FF><b>鈴鳴·狩魔之刻</b></color>中，處於「尋獵」模式下的「誘巫餌鈴」對敵人造成傷害後，若該次傷害對敵人觸發了擴散反應，則還會在敵人面前召喚出一柄依據本次擴散反應進行元素轉化的<b><span style=\"color:#FFD780FF\">「狩災誓錘」</span></b>向其砸下，造成布倫妮攻擊力150%的對應類型的元素傷害，該傷害視為元素爆發傷害。",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "振鈴同心",
      "description": "當布倫妮使用發生過元素轉化的<b><span style=\"color:#FFD780FF\">「狩災誓錘」</span></b>命中敵人後，隊伍中附近的其他角色將獲得持續5秒的「振鈴鼓舞」效果：普通攻擊、重擊、下落攻擊、元素戰技或元素爆發對敵人造成傷害時，基於其獲得「振鈴鼓舞」效果時，布倫妮攻擊力超過2000的部分，提升本次攻擊造成的傷害：每點攻擊力都會使本次攻擊造成的傷害提升0.025%，至多提升50%。",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "改裝！敲敲打打！",
      "description": "合成角色天賦素材時，有10%機率額外產生一份地區相同的其他隨機天賦素材，等階與合成後獲得的素材相同。",
      "level": 0
    }
  ],
