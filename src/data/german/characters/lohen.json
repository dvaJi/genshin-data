  "passives": [
    {
      "id": "moratorium_on_questioning",
      "name": "Zurechtweisung des Verbotenen",
      "description": "Sammelt, wenn im Zustand <b><span style=\"color:#FFD780FF\">Geniestreich</span></b> andere Truppenmitglieder in der Nähe durch verursachten Schaden <b><span style=\"color:#FFD780FF\">Siegeswille</span></b> für Lohen sammeln und der verursachte Schaden nicht unter 3.000 % von Lohens Basis-ANG liegt, zusätzlich 60 Punkte <span style=\"color:#FFD780FF\">Siegeswille</span> für Lohen an.",
      "level": 1
    },
    {
      "id": "flippant_masterpiece",
      "name": "Meisterwerk des Schauspiels",
      "description": "Erhöht im Zustand <b><span style=\"color:#FFD780FF\">Geniestreich</span></b>, wenn ein anderes Truppenmitglied in der Nähe bei Gegnern <span style=\"color:#99FFFFFF\">Kryo-Reaktionen</span> auslöst, den ANG dieser Figur sowie Lohens ANG 8 s lang um 15 %.",
      "level": 4
    },
    {
      "id": "when_the_mood_strikes",
      "name": "Flüchtiges Interesse",
      "description": "Verleiht Lohen nach dem Anwenden der Elementarfähigkeit <span style=\"color:#FFD780FF\">Unerwarteter Schachzug</span> 9 s lang den Effekt „Gute Laune“: Erhöht während der Wirkungsdauer die Fähigkeitsstufe von <span style=\"color:#FFD780FF\">Unerwarteter Schachzug</span> um 1.<br/>Verlängert, wenn beim Anwenden der Elementarfähigkeit die Fähigkeitsstufe eines Standardangriffs, einer Elementarfähigkeit oder Spezialfähigkeit eines anderen Truppenmitglieds nicht niedriger als die von Lohens Elementarfähigkeit ist, die Wirkungsdauer von dieser „Guten Laune“ zusätzlich um 6 s.<br/>„Gute Laune“ kann nur einmal alle 18 s erhalten werden.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1291,
      "id": "o_breezes_that_so_oft_bear_sorrowful_lament",
      "name": "Winde der Vergangenheit, erfüllt von Trauergesängen",
      "description": "Erhöht die Obergrenze von Lohens <b><span style=\"color:#FFD780FF\">Siegeswillen</span></b> auf 300 % des ursprünglichen Werts.<br/>Erhöht im Zustand <b><span style=\"color:#FFD780FF\">Geniestreich</span></b> zudem den <span style=\"color:#FFD780FF\">Siegeswillen</span>, den andere Truppenmitglieder in der Nähe durch verursachten Schaden für Lohen ansammeln, auf 500 % des ursprünglichen Werts.",
      "level": 1
    },
    {
      "_id": 1292,
      "id": "in_flight_i_strike_whatever_flies",
      "name": "Alles, was fliegt, ist eine Zielscheibe",
      "description": "Verleiht Lohen, nachdem er im Zustand <b><span style=\"color:#FFD780FF\">Geniestreich</span></b> einen Gegner mit der besonderen Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Bis ins Mark</span></b> getroffen oder die Spezialfähigkeit <span style=\"color:#FFD780FF\">Verhängte Strafe</span> angewendet hat, 4 s lang den Effekt „Klinge der Gerechten“: Führt, wenn Lohen im Status „Geniestreich“ das nächste Mal einen Gegner mit einem Standardangriff oder einem heftigen Schlag trifft, einen zusätzlichen Angriff aus, der <span style=\"color:#99FFFFFF\">Kryo-Flächenschaden</span> in Höhe von 500 % von Lohens ANG verursacht. Erhöht zudem 8 s lang die Elementarkunde anderer Truppenmitglieder in der Nähe um 200 Punkte. 4 s Abklingzeit auf den Erhalt des Effekts „Klinge der Gerechten“.",
      "level": 2
    },
