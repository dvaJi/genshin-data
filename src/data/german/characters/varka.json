  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "Marsch des Morgenwinds",
      "description": "Verleiht Varka, wenn sich eine <span style=\"color:#FF9999FF\">Pyro</span>-, <span style=\"color:#80C0FFFF\">Hydro</span>-, <span style=\"color:#FFACFFFF\">Elektro</span>- oder <span style=\"color:#99FFFFFF\">Kryo</span>-Figur in der Truppe befindet, gemäß der oben genannten Elemente-Priorität und basierend auf seinem ANG, für je 1.000 Pkt. ANG einen SCH-Bonus des entsprechenden Elements (von den oben genannten Elementartypen kann höchstens ein Elementartyp auf diese Weise einen SCH-Bonus erhalten) sowie einen <span style=\"color:#80FFD7FF\">Anemo-SCH-Bonus</span> von 10 %. Auf diese Weise können je max. 25 % SCH-Bonus erhalten werden.<br/><br/>Verursacht zudem, wenn sich in der Truppe mindestens 2 <span style=\"color:#80FFD7FF\">Anemo</span>-Figuren oder mindestens 2 <span style=\"color:#FF9999FF\">Pyro</span>-, <span style=\"color:#80C0FFFF\">Hydro</span>-, <span style=\"color:#FFACFFFF\">Elektro</span>- oder <span style=\"color:#99FFFFFF\">Kryo</span>-Figuren desselben Elementartyps befinden, und Varka im Modus <b><span style=\"color:#FFD780FF\">Ansturm der Winde</span></b> einen Standardangriff, heftigen Schlag, den besonderen heftigen Schlag <span style=\"color:#FFD780FF\">Azurbiss</span> oder die besondere Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span></b> anwendet, 140 % von deren ursprünglichem Schaden. Erhöht, wenn sich in der Truppe gleichzeitig mindestens 2 <span style=\"color:#80FFD7FF\">Anemo</span>-Figuren und mindestens 2 <span style=\"color:#FF9999FF\">Pyro</span>-, <span style=\"color:#80C0FFFF\">Hydro</span>-, <span style=\"color:#FFACFFFF\">Elektro</span>- oder <span style=\"color:#99FFFFFF\">Kryo</span>-Figuren desselben Elementartyps befinden, den oben genannten Effekt auf 220 %.",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "Vorhut des Windbanners",
      "description": "Verleiht Varka, wenn Truppenmitglieder in der Nähe Verwirbelung auslösen, eine Stapelung <span style=\"color:#FFD780FF\">Schwur des blauen Reißzahns</span> und erhöht dadurch von Varka mit Standardangriffen, heftigen Schlägen, dem besonderen heftigen Schlag <span style=\"color:#FFD780FF\">Azurbiss</span> und der besonderen Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span></b> verursachten Schaden um 7,5 %. Dieser Effekt hält 8 s an, ist bis zu 4-fach stapelbar. Jede Figur kann Varka höchstens einmal pro Sekunde eine Stapelung <span style=\"color:#FFD780FF\">Schwur des blauen Reißzahns</span> verleihen.",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "Siegeshymne des heimkehrenden Windes",
      "description": "Verkürzt für jede Figur aus Mondstadt in der Truppe die Abklingzeit der durch Gedrückthalten auszulösenden Elementarfähigkeit <span style=\"color:#FFD780FF\">Abflauender Sturm</span> um 5 %.<br/>Dieser Effekt gilt nicht in Sphären, Gebietssäuberungen oder im Gewundenen Abgrund.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "„Komm, Freund, lass uns im Mondlicht einen Walzer tanzen“",
      "description": "Verleiht Varka, wenn er in den Modus <b><span style=\"color:#FFD780FF\">Ansturm der Winde</span></b> wechselt, eine zusätzliche Anwendungsmöglichkeit der besonderen Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span></b>.<br/>Verleiht Varka nach dem Wechsel in den Modus <span style=\"color:#FFD780FF\">Ansturm der Winde</span> zudem den Effekt <span style=\"color:#FFD780FF\">Edler Tropfen im Lied</span>: Verbraucht diesen Effekt beim Anwenden der besonderen Elementarfähigkeit <span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span> oder des besonderen heftigen Schlags <span style=\"color:#FFD780FF\">Azurbiss</span> und lässt <span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span> oder <span style=\"color:#FFD780FF\">Azurbiss</span> 200 % des ursprünglichen Schadens verursachen.",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "„Wenn der Morgen anbricht, machen wir uns auf den Weg“",
      "description": "Führt, wenn Varka seine besondere Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span></b> oder den besonderen heftigen Schlag <span style=\"color:#FFD780FF\">Azurbiss</span> ausführt, einen zusätzlichen Angriff aus, der <span style=\"color:#80FFD7FF\">Anemo-Flächenschaden</span> in Höhe von 800 % des ANG verursacht.",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "„Freund, trinke nicht mehr den bitteren Wein, der Tränen fließen lässt“",
      "description": "Erhöht die Stufe der Elementarfähigkeit <color=#FFD780FF><b>Abflauender Sturm</b></color> um 3.<br/>Höchststufe 15.",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "„Denn niemand kann uns die Freiheit nehmen zu singen“",
      "description": "Verleiht allen Truppenmitgliedern in der Nähe, wenn Varka eine Verwirbelung auslöst, basierend auf dem Elementartyp der Reaktion, 10 s lang jeweils einen <span style=\"color:#80FFD7FF\">Anemo-SCH-Bonus</span> und einen SCH-Bonus des entsprechenden Elements von 20 %.",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
      "name": "„Füllt die Becher mit edlem Wein, Tyrannen kommen und gehen“",
      "description": "Erhöht die Stufe der Spezialfähigkeit <color=#FFD780FF><b>Ich bin der Nordwind</b></color> um 3.<br/>Höchststufe 15.",
      "level": 5
    },
    {
      "_id": 1286,
      "id": "beloved_mondstadt_steadfast_you_shall_shine",
      "name": "„Mein geliebtes Mondstadt, so standhaft wie eh und je“",
      "description": "Verstärkt den Modus <b><span style=\"color:#FFD780FF\">Ansturm der Winde</span></b>:<br/>· Ermöglicht Varka kurz nach der Ausführung der besonderen Elementarfähigkeit <b><span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span></b> durch Drücken der Elementarfähigkeit oder Gedrückthalten des Standardangriffs zusätzlich 1-mal den besonderen heftigen Schlag <span style=\"color:#FFD780FF\">Azurbiss</span> auszuführen, ohne die Anwendungsmöglichkeit von Aufkommen der vier Winde zu verbrauchen.<br/>· Ermöglicht Varka kurz nach der Ausführung des besonderen heftigen Schlags <span style=\"color:#FFD780FF\">Azurbiss</span> durch Drücken der Elementarfähigkeit zusätzlich 1-mal <span style=\"color:#FFD780FF\">Aufkommen der vier Winde</span> auszuführen, ohne die Anwendungsmöglichkeit von Aufkommen der vier Winde zu verbrauchen.<br/>Wird auf die oben beschriebenen Weisen ein zusätzlicher besonderer heftiger Schlag Azurbiss ausgeführt oder eine zusätzliche besondere Elementarfähigkeit Aufkommen der vier Winde eingesetzt, können die oben genannten Effekte nicht ausgelöst werden.<br/><br/>Verstärkt zudem den Effekt <span style=\"color:#FFD780FF\">Schwur des blauen Reißzahns</span> des Aufstiegstalents <color=#FFD780FF><b>Vorhut des Windbanners</b></color>: Erhöht Varkas KSCH pro Stapelung <span style=\"color:#FFD780FF\">Schwur des blauen Reißzahns</span> um 20 %.",
      "level": 6
    }
  ],
