  "passives": [
    {
      "id": "field_observation_notes",
      "name": "Notizen der Feldbeobachtung",
      "description": "Verringert, wenn Lumi sich auf dem Feld befindet, den <span style=\"color:#FFE699FF\">Geo-WDS</span> von Gegnern in Lumis Nähe um 15 %.<br/><br/><span style=\"color:#FFD780FF\">Mondomen – Reifer Glanz</span>: Verstärkt Linneas Elementarfähigkeit <color=#FFD780FF><b>Gegenmaßnahme – Lumis Kampfschrei!</b></color> und Spezialfähigkeit <color=#FFD780FF><b>Notiz – Überlebensratgeber für ausweglose Lagen</b></color>. Verringert, nachdem Lumi auf das Schlachtfeld gerufen wurde, den <span style=\"color:#FFE699FF\">Geo-WDS</span> von Gegnern in Lumis Nähe zusätzlich um 15 %.",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "Umfassendes Naturkundearchiv",
      "description": "Linnea erhöht basierend auf 5 % ihrer VTD die Elementarkunde bestimmter Figuren in der Truppe abhängig von der aktuellen Figur auf dem Feld. Wenn es sich bei der aktuellen Figur um folgende handelt:<br/>· Mondomen-Figur: Erhöht die Elementarkunde dieser Figur.<br/>· Keine Mondomen-Figur: Erhöht Linneas eigene Elementarkunde.",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "Mondomen-Segen – Lebensraum-Erkundung",
      "description": "Wenn eine Figur in der Truppe die Reaktion „Hydro-Kristallisation“ auslöst, wird diese in die Reaktion „Mond-Kristallisation“ umgewandelt, wobei der durch Figuren in der Truppe verursachte Basis-SCH der Reaktion „Mond-Kristallisation“ auf der Grundlage von Linneas VTD erhöht wird: Für je 100 Punkte VTD wird der Basis-SCH der Reaktion „Mond-Kristallisation“ um 0,7 % erhöht. Auf diese Weise kann der Schaden um bis zu 14 % erhöht werden.<br/><br/>Erhöht zudem die Stufe vom <span style=\"color:#FFD780FF\">Mondomen</span> der Truppe um 1, wenn sich Linnea in der Truppe befindet.",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "Abenteuerexpertin",
      "description": "Verringert, wenn Linnea sich nicht im Kampf befindet, die für einen <span style=\"color:#FFD780FF\">gezielten Schuss</span> benötigte Aufladezeit enorm und verschießt zudem einen speziellen <span style=\"color:#FFD780FF\">superduperpraktischen Pfeil</span>, der abhängig vom Ziel unterschiedliche Effekte hervorruft. Art des Ziels:<br/>· Bestimmtes Tier: Der <span style=\"color:#FFD780FF\">superduperpraktische Pfeil</span> wird zu einem speziellen „Netz“, das die essenzielle Form eines Tierchens festhalten und diese als Medium nutzen kann, um die Form des Tierchens nachzubilden. Die wöchentliche Anzahl benutzbarer „Netze“ ist begrenzt.<br/>· Erzadern mit zum Schmieden geeignetem Erz: Linnea setzt Lumi ein, um das vom <span style=\"color:#FFD780FF\">superduperpraktischen Pfeil</span> als Ziel markierte Erz zu zerstören und die verstreuten Erze einzusammeln. Wenn Lumi sich nicht auf dem Feld befindet, wird sie kurz herbeigerufen, um Linnea beim Erhalt von Erz zu helfen.<br/><br/>Verringert in diesem Fall den Schaden, den der <span style=\"color:#FFD780FF\">superduperpraktische Pfeil</span> den Gegnern zufügt, auf 20 % des ursprünglichen Schadens. Außerdem muss sich Linnea nach dem Abschießen einer bestimmten Anzahl <span style=\"color:#FFD780FF\">superduperpraktischer Pfeile</span> innerhalb kurzer Zeit kurz ausruhen, bevor sie erneut Pfeile abschießen kann.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1301,
      "id": "provisional_classification",
      "name": "Unvollständige Klassifizierung",
      "description": "Verleiht Linnea, wenn die Elementarfähigkeit <color=#FFD780FF><b>Gegenmaßnahme – Lumis Kampfschrei!</b></color> angewendet oder „Harmonie der Mondkäfige“ ausgelöst wird, 6 Stapelungen des Effekts <span style=\"color:#FFD780FF\">Chroniken der Durchsicht</span>. Dieser Effekt hält 10 s an und ist bis zu 18-fach stapelbar. Verbraucht, wenn Truppenmitglieder in der Nähe Schaden durch die Reaktion Mond-Kristallisation verursachen, 1 Stapelung „Chroniken der Durchsicht“ und erhöht den verursachten Schaden um 75 % von Linneas VTD.<br/>Außerdem kann Linnea, wenn Lumi im <color=#FFD780FF><b>Ultra-Modus</b></color> den <span style=\"color:#FFD780FF\">tonnenschweren Hammer</span> einsetzt, bis zu 5 Stapelungen „Chroniken der Durchsicht“ verbrauchen, wobei der verursachte Schaden für jede Stapelung um 150 % von Linneas VTD erhöht wird.",
      "level": 1
    },
    {
      "_id": 1302,
      "id": "tidings_of_joy_and_sorrow",
      "name": "Verkündung von Freude und Leid",
      "description": "Erhöht innerhalb von 8 s nach dem Auslösen von „Harmonie der Mondkäfige“ den kritischen Schaden aller Figuren in der Truppe, deren Elementartyp <span style=\"color:#80C0FFFF\">Hydro</span> oder <span style=\"color:#FFE699FF\">Geo</span> ist, um 40 %. Erhöht zudem, wenn Lumi im <color=#FFD780FF><b>Ultra-Modus</b></color> den <span style=\"color:#FFD780FF\">tonnenschweren Hammer</span> anwendet, dessen kritischen Schaden zusätzlich um 150 %.<br/><br/><span style=\"color:#FFD780FF\">Mondomen – Reifer Glanz</span>: Löst, wenn Lumi im <color=#FFD780FF><b>Super-Modus</b></color> den <span style=\"color:#FFD780FF\">Krafthammer</span> anwendet oder im Ultra-Modus den <span style=\"color:#FFD780FF\">tonnenschweren Hammer</span> anwendet, einmal „Harmonie der Mondkäfige“ aus. Diese „Harmonie der Mondkäfige“ wird so gewertet, als ob alle Figuren in der Truppe, deren Elementartyp <span style=\"color:#80C0FFFF\">Hydro</span> oder <span style=\"color:#FFE699FF\">Geo</span> ist, ihr Element in der Reaktion angewendet haben.",
      "level": 2
    },
    {
      "_id": 1303,
      "id": "eventful_log_page",
      "name": "Seite lebhafter Aufzeichnungen",
      "description": "Erhöht die Stufe der Elementarfähigkeit <color=#FFD780FF><b>Gegenmaßnahme – Lumis Kampfschrei!</b></color> um 3.<br/>Höchststufe 15.",
      "level": 3
    },
    {
      "_id": 1304,
      "id": "expert_instinct",
      "name": "Instinkt einer Expertin",
      "description": "Erhöht innerhalb von 5 s nach dem Auslösen von „Harmonie der Mondkäfige“ die VTD von Linnea und deiner eigenen aktuellen Figur in der Truppe jeweils um 25 %. Wenn Linnea die aktuelle Figur ist, kann die obengenannte VTD-Erhöhung gestapelt werden.",
      "level": 4
    },
    {
      "_id": 1305,
      "id": "fairylands_farewell_gift",
      "name": "Abschiedsgeschenk aus dem Zauberreich",
      "description": "Erhöht die Stufe der Spezialfähigkeit <color=#FFD780FF><b>Notiz – Überlebensratgeber für ausweglose Lagen</b></color> um 3.<br/>Höchststufe 15.",
      "level": 5
    },
    {
      "_id": 1306,
      "id": "golden_beagles_dream",
      "name": "Traum des goldenen Jagdhundes",
      "description": "Verstärkt den Effekt des Sternbilds <span style=\"color:#FFD780FF\">Unvollständige Klassifizierung</span>: Verleiht Linnea, wenn die Elementarfähigkeit <color=#FFD780FF><b>Gegenmaßnahme – Lumis Kampfschrei!</b></color> angewendet oder „Harmonie der Mondkäfige“ ausgelöst wird, direkt die maximale Anzahl an Stapelungen des Effekts <span style=\"color:#FFD780FF\">Chroniken der Durchsicht</span>. Verbraucht, wenn <span style=\"color:#FFD780FF\">Chroniken der Durchsicht</span> verbraucht wird, die doppelte Anzahl an Stapelungen und erhöht den Schadensbonus auf 150 % des ursprünglichen Werts.<br/><br/><span style=\"color:#FFD780FF\">Mondomen – Reifer Glanz</span>: <b><span style=\"color:#FFD780FF\">Steigert</span></b> den durch Truppenmitglieder in der Nähe mit der Reaktion Mond-Kristallisation verursachten Schaden um 25 %.",
      "level": 6
    }
  ],
