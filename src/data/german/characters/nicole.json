  "passives": [
    {
      "id": "methexis",
      "name": "Methexis",
      "description": "Nach dem Anwenden der Elementarfähigkeit <color=#FFD780FF><b>Verheißung des Wortes – Licht des Ungesehenen</b></color> „beobachtet“ Nicole die anderen eigenen aktuellen Truppenmitglieder 20 s lang. Stuft, nachdem die beobachtete Figur 3 s lang fortlaufend auf dem Feld war, deren Effekt <b><span style=\"color:#FFD780FF\">Gabe der Kenosis</span></b> zu <b><span style=\"color:#FFD780FF\">Führung der Theosis</span></b> hoch, und erhöht ihren ANG zusätzlich um 300 Pkt. Stuft, wenn es sich bei der beobachteten Figur um eine Hexerei-Figur handelt, deren Effekt <span style=\"color:#FFD780FF\">Gabe der Kenosis</span> direkt zu <span style=\"color:#FFD780FF\">Führung der Theosis</span> hoch.<br/>Abgesehen von Nicole wird <span style=\"color:#FFD780FF\">Führung der Theosis</span> aller anderen Figuren nach dem Verlassen des Felds wieder auf <span style=\"color:#FFD780FF\">Gabe der Kenosis</span> zurückgestuft.",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "Philokalie",
      "description": "Stuft, nachdem ein aktuelles Truppenmitglied in der Nähe einem Gegner Elementar-Schaden zugefügt hat, Nicoles eigene <b><span style=\"color:#FFD780FF\">Gabe der Kenosis</span></b> 8 s lang zu <b><span style=\"color:#FFD780FF\">Führung der Theosis</span></b> hoch.",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "Nepsis",
      "description": "Wandelt, wenn du dich in Teyvat nicht im Kampf befindest und bereits den Schatzkompass für das aktuelle Gebiet erhalten hast, Nicoles heftigen Schlag in „Führung des Boten“ um: Ruft eine Seelie in der Nähe herbei, die den Weg aufzeigt, und löst den gleichen Effekt wie der Schatzkompass des aktuellen Gebiets aus.<br/>Dieser Effekt hat eine Abklingzeit von 5 s und ist in Sphären, Gebietssäuberungen und im Gewundenen Abgrund nicht wirksam.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "„Fürchte dich nicht, geliebtes Kind der Menschheit“",
      "description": "Beschwört, wenn der Angriff deines aktuellen Truppenmitglieds einen Gegner trifft, zusätzlich ein besonderes „Arkanes Abbild – Vereinigung“ herauf, das einen abgestimmten Angriff auf den Gegner ausführt, der Flächenschaden des Elements des jeweiligen Truppenmitglieds in Höhe von 600 % von dessen ANG verursacht. Dieser Schaden gilt als von diesem Truppenmitglied verursachter Schaden.<br/>6 s Abklingzeit.",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "„Ich werde dich lehren und dir deinen eigenen Weg zeigen“",
      "description": "Verstärkt den Effekt der Elementarfähigkeit <color=#FFD780FF><b>Verheißung des Wortes – Licht des Ungesehenen</b></color>: Erhöht den ANG durch <b><span style=\"color:#FFD780FF\">Gabe der Kenosis</span></b> zusätzlich um 300 Pkt. (wird nicht in den max. ANG-Bonus dieses Effekts eingerechnet), und verringert durch <b><span style=\"color:#FFD780FF\">Führung der Theosis</span></b> zudem abhängig vom Elementartyp der Figur den Elementar-Widerstand von Gegnern in der Nähe um 25 %. Effekte zur Verringerung des Elementar-Widerstands desselben Elementartyps können nicht gestapelt werden.<br/>Außerdem gewährt Nicole aktuellen Figuren in der Nähe einen Schild aus glühendem Licht, wenn sie die Elementarfähigkeit <span style=\"color:#FFD780FF\">Verheißung des Wortes – Licht des Ungesehenen</span> anwendet.",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "„Eine Lampe an deiner Seite, ein Licht vor dir“",
      "description": "Erhöht die Stufe der Elementarfähigkeit <color=#FFD780FF><b>Verheißung des Wortes – Licht des Ungesehenen</b></color> um 3.<br/>Höchststufe 15.",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "„Nach links oder rechts, wohin auch immer du gehst“",
      "description": "Wenn bei Truppenmitgliedern in der Nähe <b><span style=\"color:#FFD780FF\">Gabe der Kenosis</span></b> zu <b><span style=\"color:#FFD780FF\">Führung der Theosis</span></b> hochgestuft wird, verleiht Nicole ihnen 20 s lang zusätzlich den Effekt „Schutz der Pfadfinder“. Eine Figur kann diesen Effekt höchstens einmal alle 16 s erhalten.<br/>Erhöht den durch Standardangriffe, heftige Schläge, Angriffe aus dem Fall, Elementarfähigkeiten und Spezialfähigkeiten von Figuren mit „Schutz der Pfadfinder“ verursachten Schaden um 70 % von Nicoles ANG. Dieser Effekt wird nach 8-maligem Auslösen oder am Ende der Dauer aufgehoben.<br/>Beim gleichzeitigen Treffen mehrerer Gegner werden je nach Anzahl der getroffenen Gegner Auslösungen verbraucht. Die Auslösungen von Figuren mit „Schutz der Pfadfinder“ werden separat gezählt.",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "„An deiner Seite wirst du meine Stimme hören“",
      "description": "Erhöht die Stufe der Spezialfähigkeit <color=#FFD780FF><b>Verheißung des Wortes – Reise zum Himmel</b></color> um 3.<br/>Höchststufe 15.",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "„Das ist der richtige Weg, zögere nicht“",
      "description": "Stuft, wenn Nicoles <b><span style=\"color:#FFD780FF\">Gabe der Kenosis</span></b> zu <b><span style=\"color:#FFD780FF\">Führung der Theosis</span></b> hochgestuft wird, gleichzeitig die <span style=\"color:#FFD780FF\">Gabe der Kenosis</span> aller Truppenmitglieder in der Nähe zu <span style=\"color:#FFD780FF\">Führung der Theosis</span> hoch. Alle <span style=\"color:#FFD780FF\">Führungen der Theosis</span> werden nicht mehr zu <span style=\"color:#FFD780FF\">Gabe der Kenosis</span> zurückgestuft.<br/>Der von Figuren mit <span style=\"color:#FFD780FF\">Führung der Theosis</span> verursachte Schaden ignoriert zudem 40 % der VTD von Gegnern.",
      "level": 6
    }
  ],
