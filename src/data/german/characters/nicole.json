  "outfits": [
    {
      "id": 213100,
      "name": "Zerfall der Mimesis",
      "description": "Nicoles Kleidung. „Dies ist ein Federgewand, gewoben aus Worten und Versen von jenem Engel, der tausend Jahre über die Erde wanderte.“ Nur ein Scherz! Wenn das oben Gesagte wahr wäre, warum sollte sie dann nicht jeden Tag ein neues Kleidungsstück tragen? Aber selbst wenn es eine solche Technik gäbe, sollten wir diese Fantasie besser aufgeben – sonst wird die Teegesellschaft noch zur Kostümgesellschaft. Wie dem auch sei, der Himmlische da oben hat den Menschen schließlich nicht verboten, sich wie ein Engel zu kleiden.",
      "isDefault": true,
      "characterName": "Nicole",
      "characterId": 10000131,
      "filename_card": "UI_AvatarIcon_Costume_Card",
      "filename_iconCircle": "UI_AvatarIcon_Nicole_Circle"
    }
  ]
