  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "Entscheidung und Strafe",
      "description": "Beschwört, wenn das „Köderglöckchen“ im Modus „Jagdsuche“ der Spezialfähigkeit <color=#FFD780FF><b>Glockenläuten! Die Jagd ist eröffnet!</b></color> einem Gegner Schaden zufügt und dieser Schaden eine Verwirbelung auslöst, die den Gegner trifft, vor dem Gegner einen <b><span style=\"color:#FFD780FF\">Hammer des Jagdschwurs</span></b>. Dieser führt eine Elementarumwandlung basierend auf der ausgelösten Verwirbelung durch, schlägt auf den Gegner ein und verursacht dabei Elementar-Schaden des entsprechenden Typs in Höhe von 150 % von Prunes ANG. Hierdurch verursachter Schaden gilt als Schaden der Spezialfähigkeit.",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "Herzschlag in Eintracht",
      "description": "Verleiht, wenn Prune einen Gegner mit dem <b><span style=\"color:#FFD780FF\">Hammer des Jagdschwurs</span></b>, der bereits eine Elementarumwandlung durchlaufen hat, trifft, anderen Truppenmitgliedern in der Nähe 5 s lang den Effekt Trommelwirbel: Erhöht, wenn Standardangriffe, heftige Schläge, Angriffe aus dem Fall, Elementarfähigkeiten oder Spezialfähigkeiten Gegnern Schaden zufügen, den durch diesen Angriff verursachte Schaden basierend auf dem Teil von Prunes ANG, der über 2.000 liegt, zu dem Zeitpunkt, an dem sie den Effekt „Trommelwirbel“ erhielten: Erhöht für jeden Punkt ANG den durch diesen Angriff verursachte Schaden um 0,025 %, bis zu 50 %.",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "Umbau! Krach, bumm!",
      "description": "Erschafft mit einer Wahrscheinlichkeit von 10 % extra ein anderes zufälliges Material für Figurentalente aus demselben Gebiet mit einer dem erhaltenen Material entsprechenden Stufe.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "Mit dem Rettungsschwur begann die Reise",
      "description": "Stellt, nachdem ein Gegner durch einen Angriff mit dem <b><span style=\"color:#FFD780FF\">Hammer des Jagdschwurs</span></b>, der bereits eine Elementarumwandlung durchlaufen hat, getroffen wurde, Prune 2 Punkte Elementarenergie wieder her, 1,8 s Abklingzeit.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "Mit Elementarkraft kann man das Gepäck gut reinigen",
      "description": "Verleiht Prune, wenn sich das „Köderglöckchen“ im Modus „Jagdsuche“ der Spezialfähigkeit <color=#FFD780FF><b>Glockenläuten! Die Jagd ist eröffnet!</b></color> befindet, zudem den Effekt „Hexenjagd“: Erhöht Prunes ANG um 10 %; erhöht den ANG, wenn das „Köderglöckchen“ und der <b><span style=\"color:#FFD780FF\">Hammer des Jagdschwurs</span></b>, der bereits eine Elementarumwandlung durchlaufen hat, einen Gegner treffen, um weitere 5 %. Durch die oben beschriebene Methode kann der ANG um bis zu 40 % erhöht werden.<br/>Entfernt, wenn während der Wirkungsdauer von „Glockenläuten! Die Jagd ist eröffnet!“ diese erneut angewendet wird, die oben genannten Effekte.",
      "level": 2
    },
    {
      "_id": 1323,
      "id": "the_caravan_exits_the_mountain_pass_the_scenery_once_more_changed",
      "name": "Die Karawane überquert die Berge, die Landschaft ändert sich erneut",
      "description": "Erhöht die Stufe der Spezialfähigkeit <color=#FFD780FF><b>Glockenläuten! Die Jagd ist eröffnet!</b></color> um 3.<br/>Höchststufe 15.",
      "level": 3
    },
    {
      "_id": 1324,
      "id": "looking_back_following_the_wind_ones_shadow_still_halved",
      "name": "Im Wind, zurückblickend – dem Schatten fehlt noch eine Hälfte",
      "description": "Wenn der <b><span style=\"color:#FFD780FF\">Hammer des Jagdschwurs</span></b> nach einer Elementarumwandlung einen Gegner trifft, prallt er ab, landet erneut auf einem Gegner in der Nähe und fügt diesem Elementar-Schaden des entsprechenden Elements in Höhe von 80 % des ANG zu.",
      "level": 4
    },
    {
      "_id": 1325,
      "id": "100_defeats_no_problem_tomorrow_we_go_again",
      "name": "Einhundert Niederlagen? Morgen nochmal",
      "description": "Erhöht die Stufe der Elementarfähigkeit <color=#FFD780FF><b>Klingeling! Klang der Hexenjagd</b></color> um 3.<br/>Höchststufe 15.",
      "level": 5
    },
    {
      "_id": 1326,
      "id": "and_thats_the_story_share_it_with_your_friends",
      "name": "Das war’s. Erzähl die Geschichte deinen Freunden!",
      "description": "Verlängert die Dauer des Modus „Jagdsuche“ des „Köderglöckchens“ der Spezialfähigkeit <color=#FFD780FF><b>Glockenläuten! Die Jagd ist eröffnet!</b></color> um 4 s.<br/>Erhöht zudem den ANG von Prune und der aktuellen Figuren in der Nähe, die unter dem Einfluss des Effekts „Trommelwirbel“ stehen, 5 s lang um 350 Punkte, wenn von „Trommelwirbel“ beeinflusste Truppenmitgliedern eine beliebige Elementarreaktion an einem Gegner ausgelöst haben.",
      "level": 6
    }
  ],
