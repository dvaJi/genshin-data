  "passives": [
    {
      "id": "eternal_speculation_engine",
      "name": "悠久の演算機関",
      "description": "<span style=\"color:#FFD780FF\">輝映・星電導</span>：元素スキル<b><span style=\"color:#FFD780FF\">事象式：自在な解析</span></b>を発動する際、ファジオの<color=#FFD780FF><b>演算負荷</b></color>が50を超えている場合、演算負荷を低下させると同時に、付近の敵に向けて発射された2発目のプリズム弾が元の400%のダメージを与える。<br/>また、ファジオの<span style=\"color:#FFD780FF\">演算負荷</span>が10低下するごとに、60秒間持続する<span style=\"color:#FFD780FF\">改良戦術</span>効果を1層獲得し、この効果は最大10層まで重ね掛けできる。サンドローネが<span style=\"color:#FFD780FF\">輝映・星電導</span>状態で元素爆発<b><span style=\"color:#FFD780FF\">事象式：Q.E.D</span></b>を発動すると、改良戦術の全ての層をクリアし、負温度エネルギー光線によって元の100%+クリアした層数×10%のダメージを与える。",
      "level": 1
    },
    {
      "id": "a_ladys_code_of_conduct",
      "name": "淑女の礼儀作法",
      "description": "サンドローネの攻撃力に基づき、元素熟知をアップさせる。攻撃力100ごとにサンドローネの元素熟知+8、この方法でアップできる元素熟知量は最大160まで。",
      "level": 4
    },
    {
      "id": "light_of_rationalisme",
      "name": "星光の祝福・理論のみを光に",
      "description": "チーム内のキャラクターが超電導反応を起こすと、超電導反応は星電導反応へと変わり、サンドローネの攻撃力に基づいて、チームのキャラクターが与える星電導反応の基礎ダメージがアップする。攻撃力100につき、星電導反応の基礎ダメージ+0.7%。この方法でアップできるダメージは最大14%まで。<br/>また、<b><span style=\"color:#FFD780FF\">極星フィールド</span></b>にいる間、サンドローネは<span style=\"color:#FFD780FF\">輝映・星電導</span>状態に入る。",
      "level": 0
    },
