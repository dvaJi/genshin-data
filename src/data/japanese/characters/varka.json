  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "暁の風の行軍",
      "description": "チーム内に<span style=\"color:#FF9999FF\">炎元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>または<span style=\"color:#99FFFFFF\">氷元素</span>キャラクターが存在する時、この優先順位に従って、ファルカの攻撃力を基準として、攻撃力1000ごとにファルカは10%の<span style=\"color:#80FFD7FF\">風元素ダメージアップ効果</span>と対応する元素のダメージアップ効果を獲得する。この方法でダメージアップ効果を獲得できるのは、1種類の元素タイプのみ。また、最大25%まで。<br/><br/>さらに、チーム内に2名以上の<span style=\"color:#80FFD7FF\">風元素</span>キャラクターが存在する場合、または2名以上の同じ元素タイプ（<span style=\"color:#FF9999FF\">炎元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>または<span style=\"color:#99FFFFFF\">氷元素</span>）のキャラクターが存在する場合、ファルカが<b><span style=\"color:#FFD780FF\">疾風怒濤</span></b>状態で行う通常攻撃、重撃、特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>、および発動する特殊元素スキル<b><span style=\"color:#FFD780FF\">出づる四風</span></b>は、本来の140%のダメージを与える。チーム内に2名以上の<span style=\"color:#80FFD7FF\">風元素</span>キャラクターと、前述した2名以上の同じ元素タイプのキャラクターが同時に存在する場合、上記の効果は220%にアップする。",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "風の御旗の導き",
      "description": "付近にいるチーム内キャラクターが拡散反応を起こした時、ファルカは<span style=\"color:#FFD780FF\">「蒼牙の誓い」</span>を1層獲得し、ファルカの通常攻撃、重撃、特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>および発動した特殊元素スキル<b><span style=\"color:#FFD780FF\">出づる四風</span></b>の与えるダメージ+7.5%。この効果は継続時間8秒、最大4層まで重ねられる。この方法によって、各キャラクターがファルカに付与できる<span style=\"color:#FFD780FF\">「蒼牙の誓い」</span>は1秒毎に1層のみ。",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "帰風の凱歌",
      "description": "チームにモンド出身のキャラクターが1人いる毎に、長押しで発動した元素スキル<span style=\"color:#FFD780FF\">堕ちる烈風</span>のクールタイム-5%。<br/>この効果は秘境、征討領域、深境螺旋では発動しない。",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "「友よ、月明かりの下で踊ろう」",
      "description": "ファルカが<b><span style=\"color:#FFD780FF\">疾風怒濤</span></b>状態に入った時、特殊元素スキル<b><span style=\"color:#FFD780FF\">出づる四風</span></b>の使用可能回数のストックを1回分獲得する。<br/>さらに、<span style=\"color:#FFD780FF\">疾風怒濤</span>状態に切り替わった後、ファルカは<span style=\"color:#FFD780FF\">「謳われる美酒」</span>を獲得し、特殊元素スキル<span style=\"color:#FFD780FF\">出づる四風</span>の発動時、または特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>を行った時、これを消費し、<span style=\"color:#FFD780FF\">出づる四風</span>または<span style=\"color:#FFD780FF\">蒼牙</span>の与えるダメージを元の200%にする。",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "「暁とともに、遠き旅路へ」",
      "description": "特殊元素スキル<b><span style=\"color:#FFD780FF\">出づる四風</span></b>発動時、または特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>を行った時、ファルカは追加攻撃を1回行い、攻撃力800%の<span style=\"color:#80FFD7FF\">風元素範囲ダメージ</span>を与える。",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "「友よ、もう涙の酒を飲むな」",
      "description": "元素スキル<color=#FFD780FF><b>堕ちる烈風</b></color>のスキルLv.+3。<br/>最大Lv.15まで。",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "「謳え、誰にも奪えない自由を」",
      "description": "ファルカが拡散反応を起こした時、反応に関わった元素タイプに応じて、周囲のチーム全員がそれぞれ20%の<span style=\"color:#80FFD7FF\">風元素</span>と対応する元素のダメージアップ効果を獲得する。継続時間10秒。",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
      "name": "「注げ美酒を、暴君は来りて去りゆく」",
      "description": "元素爆発<color=#FFD780FF><b>我こそ朔風</b></color>のスキルLv.+3。<br/>最大Lv.15まで。",
      "level": 5
    },
    {
      "_id": 1286,
      "id": "beloved_mondstadt_steadfast_you_shall_shine",
      "name": "「愛しきモンドよ、変わらぬ姿で」",
      "description": "<b><span style=\"color:#FFD780FF\">疾風怒濤</span></b>状態が次のように強化される。<br/>・特殊元素スキル<b><span style=\"color:#FFD780FF\">出づる四風</span></b>発動後の短時間、ファルカは元素スキルの一回押しまたは通常攻撃の長押しで、出づる四風の使用可能回数を消費せずに、特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>を追加で1回発動できるようになる。<br/>・特殊重撃<span style=\"color:#FFD780FF\">蒼牙</span>を行った後の短時間、ファルカは元素スキルの一回押しで、出づる四風の使用可能回数を消費せずに、<span style=\"color:#FFD780FF\">出づる四風</span>を追加で1回発動できるようになる。<br/>上記の方法で追加の特殊重撃「蒼牙」または追加の特殊元素スキル「出づる四風」を発動した際は、上記の効果を発動できない。<br/><br/>さらに、固有天賦<color=#FFD780FF><b>「風の御旗の導き」</b></color>における<span style=\"color:#FFD780FF\">「蒼牙の誓い」</span>の効果が強化される。<span style=\"color:#FFD780FF\">「蒼牙の誓い」</span>1層につき、ファルカの会心ダメージ+20%。",
      "level": 6
    }
