  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "С клятвы найти спасение странствие начинается",
      "description": "После того как <b><span style=\"color:#FFD780FF\">Клятвенный молот истребителя бедствий</span></b>, претерпевший поглощение стихии, поражает противника, Прюн восстанавливает 2 ед. энергии. Эффект может возникнуть один раз в 1,8 сек.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "Убрать груз неопрятный силы стихий помогают",
      "description": "Во время взрыва стихии <color=#FFD780FF><b>Грянул звон, началась охота</b></color>, когда колокольчик-приманка находится в режиме Охотника-ловца, Прюн получает эффект Охотимся на ведьму: сила атаки Прюн повышается на 10%, а когда колокольчик-приманка и претерпевший поглощение стихии <b><span style=\"color:#FFD780FF\">Клятвенный молот истребителя бедствий</span></b> поражают противника, её сила атаки дополнительно повышается на 5%. Максимальное повышение силы атаки, которое можно получить таким способом, составляет 40%.<br/>Повторная активация навыка Грянул звон, началась охота во время действия эффекта прерывает его.",
      "level": 2
    },
