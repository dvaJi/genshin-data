  "outfits": [
    {
      "id": 213100,
      "name": "Interprétation mimétique",
      "description": "Tenue de Nicole. « Voici la robe ailée, tissée de prose et de poésie, d'un ange qui a erré sur terre pendant des milliers d'années... » C'est une blague, bien sûr. Si c'était vrai, pourquoi cette tenue ne changerait-elle pas tous les jours ? Et pour être honnête, il vaut mieux ne pas trop s'attarder sur cette fantaisie, de peur que les goûterons ne se transforment en bals costumés. Et puis, de toute façon, ce n'est pas comme si le ciel avait interdit aux gens de se déguiser en anges...",
      "isDefault": true,
      "characterName": "Nicole",
      "characterId": 10000131,
      "filename_card": "UI_AvatarIcon_Costume_Card",
      "filename_iconCircle": "UI_AvatarIcon_Nicole_Circle"
    }
  ]
