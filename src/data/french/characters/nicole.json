  "passives": [
    {
      "id": "methexis",
      "name": "Méthexis",
      "description": "Après avoir utilisé sa compétence élémentaire <color=#FFD780FF><b>Révélation : Lumière incréée</b></color>, Nicole « observe » les autres personnages déployés de son équipe pendant 20 s. Lorsqu'un personnage observé est resté sur le terrain pendant 3 s, sa <b><span style=\"color:#FFD780FF\">grâce de kénose</span></b> est améliorée en <b><span style=\"color:#FFD780FF\">guidance de théose</span></b>, augmentant l'ATQ de 300 pts supplémentaires. Si le personnage observé est un personnage héxère, <span style=\"color:#FFD780FF\">grâce de kénose</span> est tout de suite améliorée en <span style=\"color:#FFD780FF\">guidance de théose</span>.<br/>Si un personnage autre que Nicole quitte le terrain, sa <span style=\"color:#FFD780FF\">guidance de théose</span> redevient une <span style=\"color:#FFD780FF\">grâce de kénose</span>.",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "Philocalie",
      "description": "Lorsqu'un personnage déployé de l'équipe à proximité a touché un ennemi avec des DGT élémentaires, la <b><span style=\"color:#FFD780FF\">grâce de kénose</span></b> de Nicole est améliorée en <b><span style=\"color:#FFD780FF\">guidance de théose</span></b> pendant 8 s.",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "Nepsis",
      "description": "Hors combat en Teyvat, l'attaque chargée de Nicole devient Guidance émissariale si vous avez déjà obtenu le Détecteur de trésors de la région actuelle. Guidance émissariale : Invoque les Fées proches pour indiquer la voie, déclenchant un effet similaire à celui du Détecteur de trésors de la région.<br/>Cet effet a un TdR de 5 s et ne s'applique pas dans les donjons, dans les Donjons de la conquête et dans les Profondeurs spiralées.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "« N'aie pas peur, enfant aimé »",
      "description": "Lorsque l'attaque de votre personnage déployé touche un ennemi, une projection arcanique « Unité » supplémentaire est invoquée pour lancer une attaque coordonnée contre ce dernier, infligeant des DGT élémentaires de zone selon le type du personnage. Ces DGT sont d'une valeur équivalant à 600 % de l'ATQ du personnage et sont considérés comme infligés par ce même personnage.<br/>Cet effet peut être déclenché une fois toutes les 6 s.",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "« Je te guiderai et te montrerai le chemin à suivre »",
      "description": "Les effets de la compétence élémentaire <color=#FFD780FF><b>Révélation : Lumière incréée</b></color> sont renforcés : la <b><span style=\"color:#FFD780FF\">grâce de kénose</span></b> augmente l'ATQ de 300 pts supplémentaires, ce bonus n'étant pas compté pour la limite de bonus d'ATQ, et la <b><span style=\"color:#FFD780FF\">guidance de théose</span></b> diminue la RÉS élémentaire des ennemis proches de 25 % selon le type élémentaire du personnage concerné, les effets de diminution de RÉS d'un même élément ne se cumulant pas.<br/>De plus, lorsque Nicole utilise sa compétence élémentaire <span style=\"color:#FFD780FF\">Révélation : Lumière incréée</span>, les personnages déployés de l'équipe à proximité bénéficient également d'un bouclier de lumière ardente.",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "« Une lampe à tes côtés, une lumière pour éclairer le chemin »",
      "description": "Niveau d'aptitude <color=#FFD780FF><b>Révélation : Lumière incréée</b></color> +3.<br/>Niveau max : 15",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "« Que ce soit à gauche ou à droite, peu importe où tu te tournes »",
      "description": "Lorsque la <b><span style=\"color:#FFD780FF\">grâce de kénose</span></b> d'un personnage de l'équipe à proximité est améliorée en <b><span style=\"color:#FFD780FF\">guidance de théose</span></b>, Nicole lui accorde également l'effet Bénédiction de l'éclaireur pendant 20 s, chaque personnage pouvant obtenir cet effet une fois toutes les 16 s.<br/>Les DGT infligés par les attaques normales, les attaques chargées, les attaques plongeantes, les compétences élémentaires et les déchaînements élémentaires des personnages bénéficiant d'une bénédiction de l'éclaireur augmentent d'une valeur équivalant à 70 % de l'ATQ de Nicole, cet effet étant annulé après avoir été déclenché 8 fois ou à la fin de sa durée.<br/>En touchant plusieurs ennemis en même temps, un déclenchement est comptabilisé pour chaque ennemi touché. De plus, les déclenchements des bénédiction de l'éclaireur des personnages de l'équipe sont calculés indépendamment.",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "« Tu entendras ma voix à tes côtés »",
      "description": "Niveau d'aptitude <color=#FFD780FF><b>Révélation : Échelle de l'ascension divine</b></color> +3.<br/>Niveau max : 15",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "« Voici le chemin, emprunte-le sans délai »",
      "description": "Lorsque la <b><span style=\"color:#FFD780FF\">grâce de kénose</span></b> de Nicole est améliorée en <b><span style=\"color:#FFD780FF\">guidance de théose</span></b>, la <span style=\"color:#FFD780FF\">grâce de kénose</span> de tous les personnages de l'équipe à proximité est également améliorée en <span style=\"color:#FFD780FF\">guidance de théose</span>. Une fois améliorée, la <span style=\"color:#FFD780FF\">guidance de théose</span> ne redevient plus une <span style=\"color:#FFD780FF\">grâce de kénose</span>.<br/>De plus, les DGT infligés par les personnages avec une <span style=\"color:#FFD780FF\">guidance de théose</span> ignorent 40 % de DÉF des ennemis.",
      "level": 6
    }
  ],
