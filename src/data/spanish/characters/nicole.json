  "passives": [
    {
      "id": "methexis",
      "name": "Méthexis",
      "description": "Tras usar la Habilidad Elemental, <color=#FFD780FF><b>Revelación: Luz no manifiesta</b></color>, Nicole “observará” continuamente a tu personaje en uso del equipo (a excepción de ella misma) durante 20 s. Cuando un personaje observado permanezca en el campo de batalla durante 3 s, su <b><span style=\"color:#FFD780FF\">gracia de la kénosis</span></b> mejorará a <b><span style=\"color:#FFD780FF\">guía de la teosis</span></b>, lo que aumentará su ATQ de forma adicional en 300 pts. Si el personaje observado es un personaje taumatúrgico, el efecto de <span style=\"color:#FFD780FF\">gracia de la kénosis</span> se convertirá directamente en <span style=\"color:#FFD780FF\">guía de la teosis</span>.<br/>A excepción de Nicole, cuando los demás personajes se retiren del combate, su <span style=\"color:#FFD780FF\">guía de la teosis</span> volverá a convertirse en <span style=\"color:#FFD780FF\">gracia de la kénosis</span>.",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "Filocalia",
      "description": "Cuando un personaje en uso cercano del equipo golpee a un enemigo con Daño Elemental, la <b><span style=\"color:#FFD780FF\">gracia de la kénosis</span></b> de Nicole mejorará a <b><span style=\"color:#FFD780FF\">guía de la teosis</span></b> durante 8 s.",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "Nepsis",
      "description": "Cuando Nicole se encuentre fuera de combate en una región de Teyvat en la que se haya desbloqueado la Brújula buscatesoros, su Ataque Cargado se convertirá en “Emisaria guía”, con lo que invocará a un Seelie cercano para que muestre el camino, activando un efecto similar al de la Brújula buscatesoros de la región.<br/>Este efecto tiene un TdE de 5 s, y no se activará en dominios, Dominios de la cruzada o en la Espiral del Abismo.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "“No temas, amado hijo de la humanidad”",
      "description": "Cuando tu personaje en uso del equipo golpee a un enemigo, se invocará el efecto adicional especial “proyección arcana: unidad”, que realizará un ataque coordinado contra dicho oponente. Esto infligirá Daño Elemental en el AdE del tipo elemental del personaje en cuestión. Dicho daño equivaldrá al 600% del ATQ del personaje y se considerará daño infligido por este mismo.<br/>Este efecto puede ocurrir, como máximo, una vez cada 6 s.",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "“Yo te guiaré y te mostraré el camino que has de recorrer”",
      "description": "Fortalece el efecto de la Habilidad Elemental, <color=#FFD780FF><b>Revelación: Luz no manifiesta</b></color>, de manera que <b><span style=\"color:#FFD780FF\">gracia de la kénosis</span></b> aumentará el ATQ en 300 pts. adicionales (esto no contará para el límite del Bono de ATQ de dicho efecto), y <b><span style=\"color:#FFD780FF\">guía de la teosis</span></b> reducirá la RES Elemental de los enemigos cercanos al elemento correspondiente en un 25% según el tipo elemental del personaje. La reducción de RES Elemental del mismo elemento no podrá acumularse.<br/>Además, cuando Nicole use su Habilidad Elemental, <span style=\"color:#FFD780FF\">Revelación: Luz no manifiesta</span>, le aplicará el escudo refulgellamas a los personajes en uso cercanos.",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "“Un candil que te acompaña, una luz que te ilumina el camino”",
      "description": "Aumenta el nivel de habilidad de <color=#FFD780FF><b>Revelación: Luz no manifiesta</b></color> +3.<br/>Puede ser aumentado hasta Niv. 15.",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "“Izquierda o derecha, vayas adonde vayas”",
      "description": "Cuando la <b><span style=\"color:#FFD780FF\">gracia de la kénosis</span></b> de un personaje cercano del equipo mejore a <b><span style=\"color:#FFD780FF\">guía de la teosis</span></b>, Nicole también le otorgará el efecto de “bendición pionera” durante 20 s. Cada personaje solo podrá obtener este efecto una vez cada 16 s.<br/>El daño de los Ataques Normales, Cargados y Descendentes y de las Habilidades Elementales y Definitivas de aquellos personajes que tengan la bendición pionera aumentará en una cantidad equivalente al 70% del ATQ de Nicole. Dicho efecto desaparecerá tras activarse 8 veces o cuando termine su duración.<br/>Al golpear a varios enemigos a la vez, se consumirán las cargas del efecto en función del número de enemigos golpeados. La bendición pionera de cada personaje del equipo se calculará de forma independiente.",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "“Oirás mi voz junto a ti”",
      "description": "Aumenta el nivel de habilidad de <color=#FFD780FF><b>Revelación: Escalinata del ascenso divino</b></color> +3.<br/>Puede ser aumentado hasta Niv. 15.",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "“No vaciles, pues este es el camino correcto”",
      "description": "Cuando la <b><span style=\"color:#FFD780FF\">gracia de la kénosis</span></b> de Nicole se convierta en <b><span style=\"color:#FFD780FF\">guía de la teosis</span></b>, lo mismo ocurrirá para los personajes cercanos del equipo que también tuvieran el efecto de <span style=\"color:#FFD780FF\">gracia de la kénosis</span>. Además, tras ser mejorada, la <span style=\"color:#FFD780FF\">guía de la teosis</span> no volverá a convertirse en <span style=\"color:#FFD780FF\">gracia de la kénosis</span>.<br/>Adicionalmente, el daño infligido por los personajes con <span style=\"color:#FFD780FF\">guía de la teosis</span> ignorará el 40% de la DEF del enemigo.",
      "level": 6
    }
  ],
