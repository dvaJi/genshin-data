  "outfits": [
    {
      "id": 213100,
      "name": "Interpretación de metáforas",
      "description": "Modelo de vestimenta de Nicole. “Esta es una vestimenta con plumas, tejida con palabras y poemas por un ángel que vagó por la tierra durante miles de años”. Es broma. Si eso fuera cierto, no habría ninguna razón para no estrenar un atuendo nuevo cada día. Por otro lado, aunque realmente tuviera una habilidad así, sería mejor no fantasear demasiado con ella para evitar que la hora del té se convierta en un baile de disfraces. En cualquier caso, tampoco es que aquel que se encuentra en los cielos haya prohibido que la gente se vista como un ángel.",
      "isDefault": true,
      "characterName": "Nicole",
      "characterId": 10000131,
      "filename_card": "UI_AvatarIcon_Costume_Card",
      "filename_iconCircle": "UI_AvatarIcon_Nicole_Circle"
    }
  ]
