  "passives": [
    {
      "id": "eternal_speculation_engine",
      "name": "Mecanismo de cómputo arcaico",
      "description": "<span style=\"color:#FFD780FF\">Esplendor: Superconductor Estelar</span><br/>Al usar la Habilidad Elemental, <b><span style=\"color:#FFD780FF\">Ecuación fenomenológica: Análisis diferencial</span></b>, si la <color=#FFD780FF><b>capacidad de decodificación</b></color> de Fagio supera los 50 pts., el segundo proyectil prismático disparado contra los enemigos cercanos infligirá un 400% del daño original mientras también se reduce la capacidad de decodificación.<br/>Además, por cada 10 pts. que se reduzca la <span style=\"color:#FFD780FF\">capacidad de decodificación</span> de Fagio, esta obtendrá una acumulación del efecto <span style=\"color:#FFD780FF\">mejora táctica</span> durante 60 s. Este efecto podrá acumularse un máximo de 10 veces. Cuando Sandrone use su Habilidad Definitiva, <b><span style=\"color:#FFD780FF\">Ecuación fenomenológica: Quod erat demonstrandum</span></b>, mientras está en el estado de <span style=\"color:#FFD780FF\">esplendor: Superconductor Estelar</span>, se consumirán todas las acumulaciones de mejora táctica, lo que hará que los haces de inhibición térmica inflijan un 100% de su daño original, además de un 10% adicional por cada acumulación consumida.",
      "level": 1
    },
    {
      "id": "a_ladys_code_of_conduct",
      "name": "El código de conducta de una dama",
      "description": "Por cada 100 pts. de ATQ que tenga Sandrone, su Maestría Elemental aumentará en 8 pts. Como máximo, la Maestría Elemental puede aumentar en 160 pts. de esta manera.",
      "level": 4
    },
    {
      "id": "light_of_rationalisme",
      "name": "Bendición fulgorestelar: Luz del racionalismo",
      "description": "Cuando un personaje del equipo cause una reacción de Superconductor, esta se transformará en una reacción de Superconductor Estelar. El daño base de las reacciones de Superconductor Estelar de los personajes del equipo aumentará en un 0.7% por cada 100 pts. de ATQ que tenga Sandrone. Como máximo, dicho daño puede aumentar en un 14% de esta manera.<br/>Además, Sandrone entrará en el estado de <span style=\"color:#FFD780FF\">esplendor: Superconductor Estelar</span> mientras se encuentre dentro de un <b><span style=\"color:#FFD780FF\">campo estrellapolar</span></b>.",
      "level": 0
    },
    {
      "id": "a_caucus_prelude_and_a_long_tale",
      "name": "Preludio de la hora del té y una larga historia",
      "description": "Cuando Sandrone esté en el equipo, obtendrá una recompensa de refrigerio adicional tras entregar los encargos del día a Katheryne.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1331,
      "id": "morrow_after_the_golden_dusk",
      "name": "Mañana tras el crepúsculo dorado",
      "description": "Cuando Fagio esté en el modo de <color=#FFD780FF><b>decodificación</b></color>, la velocidad de aumento de su <color=#FFD780FF><b>capacidad de decodificación</b></color> se reducirá en un 50%, y el daño de Superconductor Estelar infligido por todos los personajes del equipo aumentará en un 30%.",
      "level": 1
    },
    {
      "_id": 1332,
      "id": "an_heiress_gazed_into_the_lookingglass",
      "name": "A través del espejo se observa una heredera",
      "description": "<span style=\"color:#FFD780FF\">Esplendor: Superconductor Estelar</span><br/>Aumenta en un 40% el Daño CRIT de los rayos criocondensadores del Ataque Cargado. Además, cada vez que se dispare un rayo criocondensador, el Daño CRIT de todos los rayos criocondensadores del modo de <color=#FFD780FF><b>decodificación</b></color> actualmente activo aumentará en un 20% adicional. Este efecto puede acumularse hasta 3 veces.",
      "level": 2
    },
    {
      "_id": 1333,
      "id": "refuse_the_wake_of_dusk_the_moonlit_yoke",
      "name": "Reniega del ocaso y del yugo de la luna",
      "description": "Aumenta el nivel de habilidad del Ataque Normal <b><span style=\"color:#FFD780FF\">Ecuación fenomenológica: Deducción autoevidente</span></b> +3.<br/>Puede ser aumentado hasta Niv. 15.",
      "level": 3
    },
    {
      "_id": 1334,
      "id": "in_knowledge_lies_the_worlds_true_ground",
      "name": "Intelecto y conocimiento, los cimientos del mundo",
      "description": "Cuando Sandrone golpee a un enemigo con el daño de Superconductor Estelar, invocará un cañón de resonancia prismática adicional que realizará un ataque coordinado que infligirá una cantidad de <span style=\"color:#99FFFFFF\">Daño Cryo</span> equivalente al 125% del ATQ de Sandrone considerado como daño de Superconductor Estelar. Este efecto solo podrá ocurrir una vez cada 4 s.",
      "level": 4
    },
    {
      "_id": 1335,
      "id": "of_all_beside_she_takes_no_part",
      "name": "Obviándolo todo, ella se queda al margen",
      "description": "Aumenta el nivel de habilidad de <b><span style=\"color:#FFD780FF\">Ecuación fenomenológica: Quod erat demonstrandum</span></b> +3.<br/>Puede ser aumentado hasta Niv. 15.",
      "level": 5
    },
    {
      "_id": 1336,
      "id": "narcissus_wakes_her_eyes_upon_the_dawn",
      "name": "Narciso se despierta, ella contempla el alba",
      "description": "En el modo de <color=#FFD780FF><b>decodificación</b></color>, la tercera vez que Fagio lance su rayo criocondensador, este pasará a ser un <span style=\"color:#FFD780FF\">rayo criocondensador concentrado</span> más poderoso que se disparará de forma continua e infligirá hasta 4 golpes adicionales de <span style=\"color:#99FFFFFF\">Daño Cryo en el AdE</span> equivalentes al 100% del ATQ de Sandrone, además del daño original de los rayos criocondensadores subsecuentes.<br/><span style=\"color:#FFD780FF\">Esplendor: Superconductor Estelar</span><br/>El <span style=\"color:#FFD780FF\">rayo criocondensador concentrado</span> pasará a infligir hasta 4 golpes adicionales de <span style=\"color:#99FFFFFF\">Daño Cryo en el AdE</span> equivalentes al 80% del ATQ de Sandrone que se considerarán como daño de Superconductor Estelar.<br/>Además, el daño de Superconductor Estelar infligido por Sandrone <b><span style=\"color:#FFD780FF\">asciende</span></b> en un 20%.",
      "level": 6
    }
  ],
