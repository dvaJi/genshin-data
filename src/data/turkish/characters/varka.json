  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "\"Gel Dostum, Ayın Yumuşak Parıltısında Dans Edelim\"",
      "description": "Varka <b><span style=\"color:#FFD780FF\">Fırtına Hücumuna</span></b> geçtiğinde özel Element Becerisi <b><span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span></b> için ek bir kullanım hakkı elde eder.<br/>Ayrıca <span style=\"color:#FFD780FF\">Fırtına Hücumuna</span> geçtikten sonra Varka, <span style=\"color:#FFD780FF\">Lirik Ziyafet</span> etkisini kazanır: <span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span> özel Element Becerisi veya <span style=\"color:#FFD780FF\">Gök Yutan</span> özel Yüklü Saldırısı kullanıldığında, bu etkiyi tüketerek <span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span> veya <span style=\"color:#FFD780FF\">Gök Yutan</span> tarafından verilen orijinal Hasarın %200'ü kadar Hasar verebilir.",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "\"Şafak Söktüğünde Başlayacak Yolculuğumuz\"",
      "description": "<b><span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span></b> özel Element Becerisi veya <span style=\"color:#FFD780FF\">Gök Yutan</span> özel Yüklü Saldırısı kullanıldığında Varka ek bir vuruş yaparak Saldırısının %800'ü kadar <span style=\"color:#80FFD7FF\">Rüzgar Alan Hasarı</span> verir.",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "\"Ey Dost, Kederli Gözyaşları Döktüren Acı Şarabı İçmeyelim\"",
      "description": "<color=#FFD780FF><b>Rüzgarın İnfazı</b></color> Element Becerisinin Seviyesini 3 artırır.<br/>Maksimum yükseltme seviyesi 15'tir.",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "\"Kimse Alamaz Şarkı Söyleme Özgürlüğümüzü Elimizden\"",
      "description": "Varka bir Girdap tepkimesi tetiklediğinde tepkimeye dahil olan Element Türlerine bağlı olarak 10 saniyeliğine yakındaki tüm grup üyeleri %20 <span style=\"color:#80FFD7FF\">Rüzgar Hasarı Bonusu</span> ve ilgili Element Hasarı Bonusu kazanır.",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
