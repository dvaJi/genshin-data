  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "Şafak Rüzgarının Yürüyüşü",
      "description": "Grupta <span style=\"color:#FF9999FF\">Ateş</span>, <span style=\"color:#80C0FFFF\">Su</span>, <span style=\"color:#FFACFFFF\">Elektrik</span> veya <span style=\"color:#99FFFFFF\">Buz</span> karakteri varken, bu Element Türlerinin belirtilen öncelik sırasına göre, Varka'nın sahip olduğu her 1.000 Saldırı Varka'ya %10 <span style=\"color:#80FFD7FF\">Rüzgar Hasarı Bonusu</span> ve buna karşılık gelen bir Element Hasarı Bonusu verir. Bahsedilen Element Türlerinden yalnızca biri bu şekilde Hasar Bonusu alabilir. Bu şekilde en fazla %25 Hasar Bonusu kazanılabilir.<br/><br/>Ayrıca grupta en az 2 <span style=\"color:#80FFD7FF\">Rüzgar</span> karakteri veya aynı elementten en az 2 <span style=\"color:#FF9999FF\">Ateş</span>, <span style=\"color:#80C0FFFF\">Su</span>, <span style=\"color:#FFACFFFF\">Elektrik</span> ya da <span style=\"color:#99FFFFFF\">Buz</span> karakteri varsa Varka'nın <b><span style=\"color:#FFD780FF\">Fırtına Hücumu</span></b> modundayken kullandığı Normal Saldırılar, Yüklü Saldırılar, <span style=\"color:#FFD780FF\">Gök Yutan</span> Özel Yüklü Saldırısı ve <b><span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span></b> özel Element Becerisi, orijinal Hasarının %140'ı kadar Hasar verir. Grupta aynı anda en az 2 <span style=\"color:#80FFD7FF\">Rüzgar</span> karakteri ve <span style=\"color:#FF9999FF\">Ateş</span>, <span style=\"color:#80C0FFFF\">Su</span>, <span style=\"color:#FFACFFFF\">Elektrik</span> veya <span style=\"color:#99FFFFFF\">Buz</span> elementlerinden aynı element türünde en az 2 karakter daha varsa bahsedilen etki %220'ye yükseltilir.",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "Rüzgarın Öncüsü",
      "description": "Yakındaki grup üyeleri Girdap tepkimesi tetiklediğinde Varka bir <span style=\"color:#FFD780FF\">Mavi Dişin Yemini</span> kademesi kazanır ve 8 saniyeliğine Normal Saldırıları, Yüklü Saldırıları, <span style=\"color:#FFD780FF\">Gök Yutan</span> özel Yüklü Saldırısı ve <b><span style=\"color:#FFD780FF\">Dört Rüzgarın Yükselişi</span></b> özel Element Becerisinin verdiği Hasar %7,5 artar. 4 kademeye kadar birikebilir. Her karakter Varka'ya bu şekilde her saniye 1 kademe <span style=\"color:#FFD780FF\">Mavi Dişin Yemini</span> kazandırabilir.",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "Eve Dönen Rüzgarın Şarkısı",
      "description": "Mondstadtlı her grup üyesi başına Varka'nın <span style=\"color:#FFD780FF\">Rüzgarın İnfazı</span> Element Becerisinin Basılı Tutma halinin bekleme süresi %5 azalır.<br/>Bu etki Zindanlarda, Ezici Zindanlarda veya Hiçlik Sarmalında tetiklenmez.",
