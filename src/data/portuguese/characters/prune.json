  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "Veredito e Punição",
      "description": "Quando causar Dano contra o inimigo no Modo Caçador do Sino Chama-Bruxa do Supremo <color=#FFD780FF><b>O Sino Toca! A Caçada Chegou!</b></color>, se esse Dano desencadear Redemoinho, invoca um <b><span style=\"color:#FFD780FF\">Martelo do Juramento Livrador</span></b> que passou por Conversão Elemental do tipo de Redemoinho para golpear o inimigo em frente, causando 150% do ATQ de Prune como Dano Elemental correspondente. Esse Dano é considerado Dano de Supremo.",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "Badalar Síncrono",
      "description": "Após Prune atingir um inimigo com <b><span style=\"color:#FFD780FF\">Martelo do Juramento Livrador</span></b> que passou por Conversão Elemental, os outros membros próximos da equipe obtêm o efeito Dança dos Sinos por 5s: quando o Ataque Normal, Carregado, Imersivo, Habilidade Elemental ou Supremo causarem Dano contra um inimigo, aumenta o Dano causado por esse ataque com base em parte de ATQ de Prune que seja maior que 2.000 quando ela é afetada pelo efeito de Dança dos Sinos. Cada ponto de ATQ a mais aumenta o Dano causado por esse ataque em 0.025%. É possível aumentar até no máximo 50% dessa forma.",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "Ting-tang! Clang-bang!",
      "description": "Ao sintetizar Materiais de Talento de Personagem, há 10% de chance de obter um Material de Talento extra aleatório da mesma região. A raridade será a mesma dos materiais obtidos ao fabricar.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "A Jornada Inicia no Juramento do Resgate",
      "description": "Depois que o ataque de <b><span style=\"color:#FFD780FF\">Martelo do Juramento Livrador</span></b> que passou por uma Conversão Elemental atingir um inimigo, Prune regenerará 2 de Energia Elemental. Esse efeito pode ser desencadeado uma vez a cada 1.8s.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "Úteis para Limpar Bagagem, os Poderes Elementais São",
      "description": "Quando o Sino Chama-Bruxa do Supremo <color=#FFD780FF><b>O Sino Toca! A Caçada Chegou!</b></color> está no Modo Caçador, Prune obtém o efeito Caça às Bruxas: aumenta seu ATQ em 10%. Quando o Sino Chama-Bruxa e o <b><span style=\"color:#FFD780FF\">Martelo do Juramento Livrador</span></b> que passou por Conversão Elemental atingirem um inimigo, aumenta o ATQ em mais 5%. É possível aumentá-lo em até 40% dessa forma.<br/>Lançar O Sino Toca! A Caçada Chegou! novamente na duração do efeito removerá o efeito original acima.",
      "level": 2
    },
    {
      "_id": 1323,
      "id": "the_caravan_exits_the_mountain_pass_the_scenery_once_more_changed",
      "name": "A Caravana Cruza a Passagem da Montanha, a Paisagem Sempre Transitória",
      "description": "Aumenta o nível do <color=#FFD780FF><b>O Sino Toca! A Caçada Chegou!</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 3
    },
    {
      "_id": 1324,
      "id": "looking_back_following_the_wind_ones_shadow_still_halved",
      "name": "Olhando por trás do Vento, a Sombra Incompleta",
      "description": "Quando o <b><span style=\"color:#FFD780FF\">Martelo do Juramento Livrador</span></b> que passou por Conversão Elemental atinge um inimigo, ricocheteará em um inimigo próximo, causando 80% do ATQ como Dano do Tipo Elemental correspondente.",
      "level": 4
    },
    {
      "_id": 1325,
      "id": "100_defeats_no_problem_tomorrow_we_go_again",
      "name": "100 Derrotas para Amanhã uma Vitória",
      "description": "Aumenta o nível da <color=#FFD780FF><b>Ding-ding! Tilintar Caçador de Magia!</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 5
    },
    {
      "_id": 1326,
      "id": "and_thats_the_story_share_it_with_your_friends",
      "name": "Essa é a História! Conte-a para seus Amigos!",
      "description": "Estende a duração do Modo Caçador do Sino Chama-Bruxa do Supremo <color=#FFD780FF><b>O Sino Toca! A Caçada Chegou!</b></color> em 4s.<br/>Além disso, quando o personagem da equipe está sob o efeito Dança dos Sinos e causa qualquer reação Elemental no inimigo, aumenta o ATQ de Prune e dos outros membros próximos da equipe que possuem o efeito Dança dos Sinos em 350 por 5s.",
      "level": 6
    }
  ],
