  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "Marcha do Vento da Alvorada",
      "description": "Quando a equipe possuir personagens <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span> ou <span style=\"color:#99FFFFFF\">Cryo</span>, de acordo com a ordem de prioridade Elemental acima, cada 1.000 de ATQ de Varka aumentam o <span style=\"color:#80FFD7FF\">Bônus de Dano Anemo</span> e o Bônus do Dano Elemental correspondente em 10% dele (dentre esses elementos, só um elemento pode ganhar bônus de Dano dessa forma). É possível obter até 25% de bônus de Dano dessa forma.<br/><br/>Além disso, se a equipe possuir pelo menos 2 personagens <span style=\"color:#80FFD7FF\">Anemo</span> ou possuir pelo menos 2 personagens de Tipo Elemental <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span> ou <span style=\"color:#99FFFFFF\">Cryo</span>, os Ataques Normais, Ataques Carregados, Ataque Carregado especial <span style=\"color:#FFD780FF\">Devoração Cerúlea</span> e a Habilidade Elemental especial <b><span style=\"color:#FFD780FF\">Ascensão dos Quatro Ventos</span></b> que Varka causa ou lança enquanto está no modo <b><span style=\"color:#FFD780FF\">Investida Furacão</span></b> causarão 140% do seu Dano original. Se a equipe possuir pelo menos 2 personagens <span style=\"color:#80FFD7FF\">Anemo</span> e pelo menos 2 personagens de Tipo Elemental <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span> ou <span style=\"color:#99FFFFFF\">Cryo</span>, esse efeito é aumentado até 220%.",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "Vanguarda do Vento",
      "description": "Quando um membro próximo da equipe desencadeia Redemoinho, Varka obterá 1 acúmulo de <span style=\"color:#FFD780FF\">Juramento da Presa Cerúlea</span>, aumentando o Dano de seu Ataque Normal, Ataque Carregado, Ataque Carregado especial <span style=\"color:#FFD780FF\">Devoração Cerúlea</span> e de sua Habilidade Elemental especial <b><span style=\"color:#FFD780FF\">Ascensão dos Quatro Ventos</span></b> em 7.5% por 8s. Esse efeito pode ser acumulado até 4 vezes, e cada personagem pode fazer Varka obter 1 acúmulo de <span style=\"color:#FFD780FF\">Juramento da Presa Cerúlea</span> por segundo.",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "Hino do Retorno do Vento",
      "description": "Para cada membro de Mondstadt, a recarga da Habilidade Elemental <span style=\"color:#FFD780FF\">Execução Zéfira</span> ao manter pressionado é reduzida em 5%.<br/>Esse efeito não será produzido em domínios, Domínios Dizimados e Abismo do Espiral.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "\"Venha, meu amigo, vamos dançar sob o leve luar.\"",
      "description": "Quando Varka troca para o modo <b><span style=\"color:#FFD780FF\">Investida Furacão</span></b>, obtém 1 Uso adicional da Habilidade Elemental especial <b><span style=\"color:#FFD780FF\">Ascensão dos Quatro Ventos</span></b>.<br/>Além disso, ao trocar para o modo <span style=\"color:#FFD780FF\">Investida Furacão</span>, Varka obtém o efeito <span style=\"color:#FFD780FF\">Vinho da Canção</span>: ao lançar a Habilidade Elemental especial <span style=\"color:#FFD780FF\">Ascensão dos Quatro Ventos</span>, ou ao realizar o Ataque Carregado especial <span style=\"color:#FFD780FF\">Devoração Cerúlea</span>, consome esse efeito para causar 200% de Dano original de <span style=\"color:#FFD780FF\">Ascensão dos Quatro Ventos</span> ou de <span style=\"color:#FFD780FF\">Devoração Cerúlea</span>.",
      "level": 1
