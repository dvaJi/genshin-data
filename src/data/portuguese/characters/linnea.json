  "passives": [
    {
      "id": "field_observation_notes",
      "name": "Anotações de Observação de Campo",
      "description": "Quando Lumi está em campo, ela reduz a <span style=\"color:#FFE699FF\">RES Geo</span> dos inimigos próximos em 15%.<br/><br/><span style=\"color:#FFD780FF\">Presságio Lunar: Reluzir Cheio</span>: fortalece a Habilidade Elemental <color=#FFD780FF><b>Contramedida: Grito de Guerra de Lumi!</b></color> e o Supremo <color=#FFD780FF><b>Lembrança: Guia de Sobrevivência Extremo</b></color> de Linnea. Depois de invocar Lumi, ela reduz a <span style=\"color:#FFE699FF\">RES Geo</span> dos inimigos próximos em mais 15%.",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "Arquivo Naturalista Universal",
      "description": "Linnea aumenta a Proficiência Elemental de certos personagens da equipe com base em 5% de sua DEF de acordo com o personagem ativo.<br/>· Para personagens de Presságio Lunar: aumenta a Proficiência Elemental desse personagem.<br/>· Para personagens que não são de Presságio Lunar: aumenta a Proficiência Elemental de Linnea.",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "Bênção do Presságio Lunar: Inspeção Residencial",
      "description": "Quando um membro da equipe desencadeia Cristalização Hydro, converte para Cristalização Lunar, e aumenta o Dano Básico de Cristalização Lunar com base na DEF de Linnea: aumenta o Dano Básico de Cristalização Lunar em 0.7% a cada 100 de DEF. É possível aumentar em até 14% dessa forma.<br/><br/>Além disso, quando Linnea está na equipe, aumenta o nível de <span style=\"color:#FFD780FF\">Presságio Lunar</span> em 1.",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "Grande Mestre Aventureira",
      "description": "Quando não está em combate, o tempo de carregamento do <span style=\"color:#FFD780FF\">Disparo com Mira</span> de Linnea é reduzido consideravelmente, e ela disparará uma <span style=\"color:#FFD780FF\">Flecha Rápida Super Conveniente</span>. Efeitos diferentes ocorrerão dependendo do alvo atingido:<br/>· Certos animais: a <span style=\"color:#FFD780FF\">Flecha Rápida Super Conveniente</span> será transformada em uma rede que pode capturar a essência e forma dos animais, usando-as como meio para manifestar a forma física do animal novamente. A rede só pode ser utilizada uma certa quantidade de vezes por semana.<br/>· Veios de minérios de forjamento: Linnea envia Lumi, que rapidamente golpeia os minérios marcados pela <span style=\"color:#FFD780FF\">Flecha Rápida Super Conveniente</span>, e então coleta esses minérios. Se Lumi não estiver no campo, Linnea a invoca por uma curta duração para ajudar a obter os minérios.<br/><br/>O Dano causado contra oponentes pela <span style=\"color:#FFD780FF\">Flecha Rápida Super Conveniente</span> de Linnea é reduzido em 20% do seu Dano de Flecha Carregada. Além disso, depois de disparar um certo número de <span style=\"color:#FFD780FF\">Flechas Rápidas Super Convenientes</span> dentro de um curto período de tempo, Linnea precisa descansar antes de poder usá-las novamente.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1301,
      "id": "provisional_classification",
      "name": "Catálogo Incompleto",
      "description": "Ao lançar a Habilidade Elemental <color=#FFD780FF><b>Contramedida: Grito de Guerra de Lumi!</b></color>, ou ao desencadear Sonata da Jaula Lunar, Linnea ganha 6 acúmulos de <span style=\"color:#FFD780FF\">Registro de Campo</span> por 10s. Máximo de 18 acúmulos. Quando um membro próximo da equipe causa Dano de Cristalização Lunar, consome 1 acúmulo de Registro de Campo para aumentar o Dano causado. O aumento de Dano é equivalente a 75% da DEF de Linnea.<br/>Além disso, quando Lumi usa <span style=\"color:#FFD780FF\">Esmagador de Milionárias Toneladas</span> na sua <color=#FFD780FF><b>Forma de Poder Supremo</b></color>, Linnea pode consumir até 5 acúmulos de Registro de Campo. Cada acúmulo aumenta o Dano causado em 150% da DEF de Linnea.",
      "level": 1
    },
    {
      "_id": 1302,
      "id": "tidings_of_joy_and_sorrow",
      "name": "Presságios de Alegria e Sofrimento",
      "description": "Nos 8s após desencadear uma Sonata da Jaula Lunar, todos os membros <span style=\"color:#80C0FFFF\">Hydro</span> e <span style=\"color:#FFE699FF\">Geo</span> da equipe têm um aumento de 40% do Dano CRIT. Além disso, quando Lumi usa o <span style=\"color:#FFD780FF\">Esmagador de Milionárias Toneladas</span> na sua <color=#FFD780FF><b>Forma de Poder Supremo</b></color>, o Dano CRIT desse ataque aumenta em mais 150%.<br/><br/><span style=\"color:#FFD780FF\">Presságio Lunar: Reluzir Cheio</span>: quando Lumi usa <span style=\"color:#FFD780FF\">Martelo Pesado da Sobrecarga</span> na sua <color=#FFD780FF><b>Forma Superpoderosa</b></color>, ou quando usa o <span style=\"color:#FFD780FF\">Esmagador de Milionárias Toneladas</span> na Forma de Poder Supremo, uma instância de Sonata da Jaula Lunar será ativada. Nessa instância de Sonata da Jaula Lunar, todos os personagens <span style=\"color:#80C0FFFF\">Hydro</span> e <span style=\"color:#FFE699FF\">Geo</span> na equipe serão considerados como se tivessem aplicado seus Elementos na reação.",
      "level": 2
    },
    {
      "_id": 1303,
      "id": "eventful_log_page",
      "name": "Página do Diário Marcante",
      "description": "Aumenta o nível da <color=#FFD780FF><b>Contramedida: Grito de Guerra de Lumi!</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 3
    },
    {
      "_id": 1304,
      "id": "expert_instinct",
      "name": "Instinto Especialista",
      "description": "Nos 5s depois de desencadear a Sonata da Jaula Lunar, aumenta a DEF de Linnea e dos membros ativos da equipe 25% cada. Quando Linnea é a personagem ativa, esse aumento de DEF pode ser acumulado.",
      "level": 4
    },
    {
      "_id": 1305,
      "id": "fairylands_farewell_gift",
      "name": "Presente de Despedida da Terra Natal",
      "description": "Aumenta o nível do Supremo <color=#FFD780FF><b>Lembrança: Guia de Sobrevivência Extremo</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 5
    },
    {
      "_id": 1306,
      "id": "golden_beagles_dream",
      "name": "Sonho do Cão Dourado",
      "description": "Os efeitos da Constelação <span style=\"color:#FFD780FF\">Catálogo Incompleto</span> são fortalecidos: ao lançar a Habilidade Elemental <color=#FFD780FF><b>Contramedida: Grito de Guerra de Lumi!</b></color>, ou ao desencadear uma Sonata da Jaula Lunar, Linnea ganhará diretamente o número máximo de acúmulos de <span style=\"color:#FFD780FF\">Registro de Campo</span>. Ao consumir <span style=\"color:#FFD780FF\">Registro de Campo</span>, consome um número de acúmulos igual ao dobro do número original, de forma que o aumento de Dano será aumentado em 150% do valor original.<br/><br/><span style=\"color:#FFD780FF\">Presságio Lunar: Reluzir Cheio</span>: o Dano de Cristalização Lunar causado por membros próximos da equipe será <b><span style=\"color:#FFD780FF\">elevado</span></b> em 25%.",
      "level": 6
    }
  ],
