  "passives": [
    {
      "id": "moratorium_on_questioning",
      "name": "Questionamento Proibido",
      "description": "Quando está no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b>, quando o Dano causado pelos outros personagens próximos acumular <b><span style=\"color:#FFD780FF\">Luta pela Vitória</span></b> para Lohen, se esse Dano não for menor que 3000% do ATQ Básico de Lohen, acumula 60 pontos adicionais de <span style=\"color:#FFD780FF\">Luta pela Vitória</span> para Lohen.",
      "level": 1
    },
    {
      "id": "flippant_masterpiece",
      "name": "Brincadeira Primorosa",
      "description": "Quando está no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b>, nos 8s após os outros membros da equipe desencadearem uma <span style=\"color:#99FFFFFF\">reação Cryo</span> no inimigo, aumenta o ATQ desse personagem em 15% e o ATQ de Lohen em 15%.",
      "level": 4
    },
    {
      "id": "when_the_mood_strikes",
      "name": "Interesse Efêmero",
      "description": "Depois de lançar a Habilidade Elemental <span style=\"color:#FFD780FF\">Ataque Surpresa</span>, Lohen obtém o efeito Animado por 9s: nessa duração, aumenta o nível de sua Habilidade Elemental <span style=\"color:#FFD780FF\">Ataque Surpresa</span> em 1.<br/>Ao lançar a Habilidade Elemental, se os níveis dos Ataques Normais, Habilidades Elementais ou Supremos dos outros personagens da equipe não forem menores que o nível da Habilidade Elemental de Lohen, a duração desse Animado é estendida em 6s adicionais.<br/>É possível desencadear Animado uma vez a cada 18s.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1291,
      "id": "o_breezes_that_so_oft_bear_sorrowful_lament",
      "name": "Brisa Funesta do Passado",
      "description": "Aumenta o limite máximo de <b><span style=\"color:#FFD780FF\">Luta pela Vitória</span></b> de Lohen em 300%.<br/>Além disso, quando está no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b>, aumenta o acúmulo de <span style=\"color:#FFD780FF\">Luta pela Vitória</span> para Lohen através do Dano causado por outros personagens próximos em 500% a mais do que o original.",
      "level": 1
    },
    {
      "_id": 1292,
      "id": "in_flight_i_strike_whatever_flies",
      "name": "Aquilo que Voa Vira Alvo",
      "description": "Quando está no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b>, nos 4s após Habilidade Elemental especial <b><span style=\"color:#FFD780FF\">Entalhado em Alma e Osso</span></b> acertar um oponente ou o lançar o Supremo <span style=\"color:#FFD780FF\">Julgamento Manifestado</span> for desencadeado, Lohen obtém o efeito Lâmina Destruidora de Demônios: quando estiver no estado Golpe de Mestre, o próximo Ataque Normal ou Carregado de Lohen que atingir o inimigo fará um ataque perseguidor adicional causando 500% do ATQ de Lohen como <span style=\"color:#99FFFFFF\">Dano Cryo em AdE</span>, e aumenta a Proficiência Elemental dos outros membros próximos da equipe em 200 por 8s. É possível desencadear o efeito Lâmina Destruidora de Demônios uma vez a cada 4s.",
      "level": 2
    },
    {
      "_id": 1293,
      "id": "only_the_spear_that_wounds_can_heal",
      "name": "Apenas a Lâmina Pode Curar Esta Ferida",
      "description": "Aumenta o nível da Habilidade Elemental <color=#FFD780FF><b>Ataque Surpresa</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 3
    },
    {
      "_id": 1294,
      "id": "radiant_love_laughing_death",
      "name": "Amor Brilhante Passa como uma Canção",
      "description": "Quando Lohen está no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b> e lançar o Supremo <span style=\"color:#FFD780FF\">Julgamento Manifestado</span>, Lohen acumula o máximo de <b><span style=\"color:#FFD780FF\">Luta pela Vitória</span></b>., fazendo com que o efeito de aumento de Dano do Supremo seja o maior possível.<br/><br/>Além disso, quando Lohen troca para o estado <span style=\"color:#FFD780FF\">Golpe de Mestre</span>, se sua Energia Elemental:<br/>· Não estiver cheia: regenera 15 de Energia Elemental para Lohen.<br/>· Se já estiver cheia: regenera 15 de Energia Elemental para Lohen nos 15s após lançar o Supremo <span style=\"color:#FFD780FF\">Julgamento Manifestado</span>.",
      "level": 4
    },
    {
      "_id": 1295,
      "id": "never_ask_nor_trouble_you_to_know",
      "name": "Inescrutável e Inquestionável",
      "description": "Aumenta o nível do Supremo <color=#FFD780FF><b>Julgamento Manifestado</b></color> em 3.<br/>O nível máximo de elevação é 15.",
      "level": 5
    },
    {
      "_id": 1296,
      "id": "to_drown_to_sink_unconscious_supreme_joy",
      "name": "Corpo Desfeito, Alma Dissipada, Alegria Sobrada",
      "description": "Quando a Habilidade Elemental especial <b><span style=\"color:#FFD780FF\">Entalhado em Alma e Osso</span></b> atingir um inimigo ou lançar o Supremo <span style=\"color:#FFD780FF\">Julgamento Manifestado</span> no estado <b><span style=\"color:#FFD780FF\">Golpe de Mestre</span></b> não consumirá <b><span style=\"color:#FFD780FF\">Luta pela Vitória</span></b>, mas fará Lohen acumular o máximo de <b><span style=\"color:#FFD780FF\">Alegria</span></b>. Quando estiver no máximo, quando ele lançar a Habilidade Elemental especial <span style=\"color:#FFD780FF\">Entalhado em Alma e Osso</span> novamente e caso acerte um oponente, prolonga a duração do estado <span style=\"color:#FFD780FF\">Golpe de Mestre</span> em 1.25s. Esse efeito pode ser desencadeado uma vez a cada 7s.<br/>Além disso, aumenta o Dano CRIT de todos os Danos acima em 175%, e o número de vezes que Lohen pode desencadear <span style=\"color:#FFD780FF\">Entalhado em Alma e Osso</span> durante essa instância de <span style=\"color:#FFD780FF\">Golpe de Mestre</span> é aumentado em 2.",
      "level": 6
    }
