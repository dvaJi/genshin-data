  "passives": [
    {
      "id": "methexis",
      "name": "Methexis",
      "description": "For 20s after unleashing the Elemental Skill <color=#FFD780FF><b>Revelation: Uncreated Light</b></color>, Nicole will continuously \"observe\" the other current active party members. After the observed character has remained on the field for 3s, their <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> is upgraded to <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b>, increasing their ATK by an additional 300. If the observed character is a Hexerei character, <span style=\"color:#FFD780FF\">Grace of Kenosis</span> is upgraded to <span style=\"color:#FFD780FF\">Guidance of Theosis</span> straight away.<br/>When characters other than Nicole who have <span style=\"color:#FFD780FF\">Guidance of Theosis</span> leave the field, their effect reverts to <span style=\"color:#FFD780FF\">Grace of Kenosis</span>.",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "Philokalia",
      "description": "When Elemental DMG from nearby active party members hits an opponent, Nicole's own <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> effect is upgraded to <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b> for 8s.",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "Nepsis",
      "description": "When you are in Teyvat and not in combat, Nicole's Charged Attack becomes \"Emissarial Guidance\" if you have already obtained the current region's Treasure Compass. Emissarial Guidance: Calls upon nearby Seelie to show the way, triggering an effect similar to the region's Treasure Compass.<br/>This effect has a cooldown time of 5 seconds and does not work in Domains, Trounce Domains, and the Spiral Abyss.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "\"Do Not Be Afraid, Child Who Is Loved\"",
      "description": "When the current active character of your own in the party hits an opponent, an additional special \"Arcane Projection: Unity\" will be summoned to perform a Coordinated Attack against the opponent, dealing AoE Elemental DMG of the character's corresponding Elemental Type at 600% of their ATK. This DMG will be considered as having been dealt by the corresponding character.<br/>This effect can trigger once every 6s.",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "\"I Will Guide You and Show You the Path You Should Tread\"",
      "description": "Enhances the effects of the Elemental Skill <color=#FFD780FF><b>Revelation: Uncreated Light</b></color>: <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> increases ATK by an additional 300 (which does not count toward this effect's ATK Bonus limit), while <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b> decreases nearby opponents' Elemental RES based on the corresponding character's Elemental Type by 25%. This effect does not stack for the same Element.<br/>Additionally, when Nicole unleashes her Elemental Skill <span style=\"color:#FFD780FF\">Revelation: Uncreated Light</span>, nearby active party members will also gain a Shield of Blazing Light.",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "\"A Lamp by Your Side, A Light to Shine the Way\"",
      "description": "Increases the Level of <color=#FFD780FF><b>Revelation: Uncreated Light</b></color> by 3.<br/>Maximum upgrade level is 15.",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "\"Whether Left or Right, No Matter Which Way You Turn\"",
      "description": "When nearby party members have their <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> upgraded to <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b>, Nicole also bestows upon them the Pathfinder's Blessing effect for 20s. Each character can gain this effect once every 16s.<br/>The Normal Attack, Charged Attack, Plunging Attack, Elemental Skill, and Elemental Burst DMG of characters with Pathfinder's Blessing is increased by 70% of Nicole's ATK. This effect will be removed once it has taken effect 8 times or when its duration is over.<br/>When multiple opponents are hit at once, instances of Pathfinder's Blessing are consumed equal to the number of opponents hit. Each character's Pathfinder's Blessing is counted independently.",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "\"You Will Hear My Voice Beside You\"",
      "description": "Increases the Level of <color=#FFD780FF><b>Revelation: Ladder of Divine Ascent</b></color> by 3.<br/>Maximum upgrade level is 15.",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "\"This Is the Path, Walk It Without Delay\"",
      "description": "When Nicole's <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> is upgraded to <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b>, all nearby party members' <span style=\"color:#FFD780FF\">Grace of Kenosis</span> will also be upgraded to <span style=\"color:#FFD780FF\">Guidance of Theosis</span>. Once upgraded, <span style=\"color:#FFD780FF\">Guidance of Theosis</span> will no longer revert to <span style=\"color:#FFD780FF\">Grace of Kenosis</span>.<br/>Additionally, DMG dealt by characters with <span style=\"color:#FFD780FF\">Guidance of Theosis</span> will ignore 40% of opponents' DEF.",
      "level": 6
    }
  ],
