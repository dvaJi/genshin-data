  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "Verdict and Punishment",
      "description": "During the Elemental Burst <color=#FFD780FF><b>The Bell Tolls! The Hunt Is On!</b></color>, after the Witchlure Bell in Hunter-Seeker mode deals DMG to an opponent, if this DMG triggers Swirl on an opponent, it will also summon a <b><span style=\"color:#FFD780FF\">Banehunter Oathhammer</span></b> that will deal 150% of Prune's ATK as DMG to them, with the DMG Type matching the Elemental Conversion from the Swirl. This DMG is considered Elemental Burst DMG.",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "Tolling Synchronicity",
      "description": "After Prune hits an opponent with the <b><span style=\"color:#FFD780FF\">Banehunter Oathhammer</span></b> that has undergone Elemental Conversion, other nearby party members will gain the Tolling Rally effect for 5s: When Normal, Charged, or Plunging Attacks, or Elemental Skills and Bursts deal DMG to opponents, that attack's DMG will be increased based on the portion of Prune's ATK in excess of 2,000 when they become affected by the Tolling Rally effect. Every excess ATK point increases that instance of DMG by 0.025%, up to a total of 50% max.",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "Tinker-Tink, Clank, and Bang!",
      "description": "Has a 10% chance to get 1 regional Character Talent Material (base material excluded) when crafting. The rarity is the same as the resulting material.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "With a Vow to Rescue, the Journey Begins",
      "description": "After the <b><span style=\"color:#FFD780FF\">Banehunter Oathhammer</span></b> that has undergone Elemental Conversion hits an opponent, Prune will regain 2 Energy. This effect can occur once every 1.8s.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "Useful for Cleaning Messy Baggage, Elemental Powers Are Indeed",
      "description": "During the Elemental Burst <color=#FFD780FF><b>The Bell Tolls! The Hunt Is On!</b></color>, when the Witchlure Bell is in Hunter-Seeker mode, Prune gains the Hunt the Witch effect: Prune's ATK increases by 10%, and when the Witchlure Bell and the <b><span style=\"color:#FFD780FF\">Banehunter Oathhammer</span></b> that has undergone Elemental Conversion hits an opponent, it further increases her ATK by 5%. Prune's ATK can be increased by up to 40% in this way.<br/>The original instance of the above effect will be removed if \"The Bell Tolls! The Hunt Is On!\" is used again during this time.",
      "level": 2
    },
    {
      "_id": 1323,
      "id": "the_caravan_exits_the_mountain_pass_the_scenery_once_more_changed",
      "name": "The Caravan Exits the Mountain Pass, the Scenery Once More Changed",
      "description": "Increases the Level of <color=#FFD780FF><b>The Bell Tolls! The Hunt Is On!</b></color> by 3.<br/>Maximum upgrade level is 15.",
      "level": 3
    },
    {
      "_id": 1324,
      "id": "looking_back_following_the_wind_ones_shadow_still_halved",
      "name": "Looking Back Following the Wind, One's Shadow Still Halved",
      "description": "After the <b><span style=\"color:#FFD780FF\">Banehunter Oathhammer</span></b> that has undergone Elemental Conversion hits an opponent, it will ricochet and land on a nearby opponent, dealing 80% ATK as DMG of the corresponding Elemental Type.",
      "level": 4
    },
    {
      "_id": 1325,
      "id": "100_defeats_no_problem_tomorrow_we_go_again",
      "name": "100 Defeats? No Problem, Tomorrow, We Go Again",
      "description": "Increases the Level of <color=#FFD780FF><b>Ring-A-Ding-Ding! Hexhunter Chime</b></color> by 3.<br/>Maximum upgrade level is 15.",
      "level": 5
    },
    {
      "_id": 1326,
      "id": "and_thats_the_story_share_it_with_your_friends",
      "name": "And That's the Story! Share It With Your Friends!",
      "description": "The duration of the Witchlure Bell's Hunter-Seeker mode from the Elemental Burst <color=#FFD780FF><b>The Bell Tolls! The Hunt Is On!</b></color> is extended by 4s.<br/>Additionally, after party members affected by Tolling Rally trigger any Elemental Reaction, they will cause Prune and the other current active character(s) affected by Tolling Rally to gain 350 ATK for 5s.",
      "level": 6
    }
  ],
