  "passives": [
    {
      "id": "field_observation_notes",
      "name": "野外观察手记",
      "description": "露米在场上时，露米附近敌人的<span style=\"color:#FFE699FF\">岩元素抗性</span>会降低15%。<br/><br/><span style=\"color:#FFD780FF\">月兆·满辉</span>：莉奈娅的元素战技<color=#FFD780FF><b>对策·露米呀吼吼！</b></color>和元素爆发<color=#FFD780FF><b>备忘·绝境生存指南</b></color>获得强化，呼唤露米上场后，露米附近敌人的<span style=\"color:#FFE699FF\">岩元素抗性</span>还会进一步降低15%。",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "万类博物图鉴",
      "description": "依据队伍中自己的当前场上角色，莉奈娅会提升队伍中特定角色的元素精通，提升值基于莉奈娅防御力的5%。若队伍中自己的当前场上角色：<br/>·为月兆角色：提升该角色的元素精通；<br/>·不为月兆角色：提升莉奈娅自己的元素精通。",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "月兆祝赐·栖地考察",
      "description": "队伍中的角色触发水元素结晶反应时，将转为触发月结晶反应，且基于莉奈娅的防御力，提升队伍中角色造成的月结晶反应的基础伤害：每100点防御力都将提升0.7%月结晶反应的基础伤害，至多通过这种方式提升14%伤害。<br/><br/>此外，莉奈娅在队伍中时，队伍的<span style=\"color:#FFD780FF\">月兆</span>将会上升一级。",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "大师级的冒险者",
      "description": "不处于战斗状态下时，莉奈娅进行<span style=\"color:#FFD780FF\">瞄准射击</span>所需的蓄力时间大幅减少，并会转为射出特制的<span style=\"color:#FFD780FF\">超便利快捷矢</span>，依据命中的目标，产生不同的效果。若命中的目标为：<br/>·特定动物：<span style=\"color:#FFD780FF\">超便利快捷矢</span>会转化为特殊的「网」，可以拘出小动物的神形，并以其为媒介，再次化出小动物的形体；每周可使用的「网」数量有限。<br/>·锻造用矿石的矿脉：莉奈娅会派出露米，快速破坏被<span style=\"color:#FFD780FF\">超便利快捷矢</span>标记的矿体，并收集掉落的矿石。若露米不在场上，则会短暂呼唤出露米，帮助莉奈娅获取矿石。<br/><br/><span style=\"color:#FFD780FF\">超便利快捷矢</span>对敌人造成的伤害降低为原本的20%。此外，短时间内发射一定数量的<span style=\"color:#FFD780FF\">超便利快捷矢</span>后，莉奈娅需要进行短暂的休息，才能继续发射。",
      "level": 0
    }
  ],
