  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "晓风的行军",
      "description": "队伍中存在<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色时，按照上述元素类型的优先级，基于法尔伽的攻击力，每1000点攻击力都将使法尔伽获得10%<span style=\"color:#80FFD7FF\">风元素伤害加成</span>与对应元素伤害加成（上述元素类型中，至多有一种元素类型可以通过这种方式获得伤害加成），至多通过这种方式获得25%。<br/><br/>此外，如果队伍中存在至少2名<span style=\"color:#80FFD7FF\">风元素</span>角色，或存在至少2名元素类型相同的<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色，法尔伽在<b><span style=\"color:#FFD780FF\">狂飙突进</span></b>模式下进行的普通攻击、重击、特殊重击<span style=\"color:#FFD780FF\">苍噬</span>与施放的特殊元素战技<b><span style=\"color:#FFD780FF\">四风将起</span></b>将造成原本140%的伤害；若队伍中同时存在至少2名<span style=\"color:#80FFD7FF\">风元素</span>角色与至少2名元素类型相同的<span style=\"color:#FF9999FF\">火元素</span>、<span style=\"color:#80C0FFFF\">水元素</span>、<span style=\"color:#FFACFFFF\">雷元素</span>或<span style=\"color:#99FFFFFF\">冰元素</span>角色，则会使上述效果提升至220%。",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "风帜的先引",
      "description": "队伍中附近的角色触发扩散反应时，法尔伽将获得一层<span style=\"color:#FFD780FF\">「苍牙之誓」</span>，使法尔伽的普通攻击、重击、特殊重击<span style=\"color:#FFD780FF\">苍噬</span>与施放的特殊元素战技<b><span style=\"color:#FFD780FF\">四风将起</span></b>造成的伤害提升7.5%。该效果持续8秒，至多叠加4层，每名角色每1秒至多通过这种方式使法尔伽获得一层<span style=\"color:#FFD780FF\">「苍牙之誓」</span>。",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "归风的凯歌",
      "description": "队伍中每有一名蒙德角色，通过长按施放的元素战技<span style=\"color:#FFD780FF\">烈风终坠</span>的冷却时间就会缩短5%。<br/>该效果在秘境、征讨领域、深境螺旋中无效。",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "「来吧，朋友，让我们在月下共舞」",
      "description": "法尔伽切换至<b><span style=\"color:#FFD780FF\">狂飙突进</span></b>模式时，将额外获得一次特殊元素战技<b><span style=\"color:#FFD780FF\">四风将起</span></b>的可用次数。<br/>此外，切换至<span style=\"color:#FFD780FF\">狂飙突进</span>模式后，法尔伽将获得<span style=\"color:#FFD780FF\">「歌中的佳酿」</span>效果：施放特殊元素战技<span style=\"color:#FFD780FF\">四风将起</span>时，或进行特殊重击<span style=\"color:#FFD780FF\">苍噬</span>时，将消耗该效果，使<span style=\"color:#FFD780FF\">四风将起</span>或<span style=\"color:#FFD780FF\">苍噬</span>造成原本200%的伤害。",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "「待天光破晓，我们便要踏上征途」",
      "description": "施放特殊元素战技<b><span style=\"color:#FFD780FF\">四风将起</span></b>时，或进行特殊重击<span style=\"color:#FFD780FF\">苍噬</span>时，法尔伽将会进行一次额外攻击，造成800%攻击力的<span style=\"color:#80FFD7FF\">风元素范围伤害</span>。",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "「朋友，莫要再饮令人落泪的苦酒」",
      "description": "元素战技<color=#FFD780FF><b>烈风终坠</b></color>的技能等级提高3级。<br/>至多提升至15级。",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "「因为无人能夺去我们歌唱的自由」",
      "description": "法尔伽触发扩散反应时，依据参与反应的元素类型，使队伍中附近的所有角色分别获得20%<span style=\"color:#80FFD7FF\">风元素伤害加成</span>与对应元素伤害加成，持续10秒。",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
      "name": "「斟满杯中佳酿吧，暴君来了又去」",
      "description": "元素爆发<color=#FFD780FF><b>我即朔风</b></color>的技能等级提高3级。<br/>至多提升至15级。",
      "level": 5
    },
    {
      "_id": 1286,
      "id": "beloved_mondstadt_steadfast_you_shall_shine",
      "name": "「我心爱的蒙德呀，依然屹立如初」",
      "description": "<b><span style=\"color:#FFD780FF\">狂飙突进</span></b>模式获得强化：<br/>·施放特殊元素战技<b><span style=\"color:#FFD780FF\">四风将起</span></b>后的短暂时间内，法尔伽可以点按元素战技或长按普通攻击，不消耗四风将起的可用次数，进行一次额外的特殊重击<span style=\"color:#FFD780FF\">苍噬</span>；<br/>·进行特殊重击<span style=\"color:#FFD780FF\">苍噬</span>后的短暂时间内，法尔伽可以点按元素战技，不消耗四风将起的可用次数，施放一次额外的<span style=\"color:#FFD780FF\">四风将起</span>。<br/>通过上述方式进行额外的特殊重击苍噬或施放额外的特殊元素战技四风将起时，无法触发上述效果。<br/><br/>此外，突破天赋<color=#FFD780FF><b>「风帜的先引」</b></color>中<span style=\"color:#FFD780FF\">「苍牙之誓」</span>的效果获得强化：每层<span style=\"color:#FFD780FF\">「苍牙之誓」</span>还会使法尔伽的暴击伤害提升20%。",
      "level": 6
    }
  ],
