  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "裁断追惩",
      "description": "元素爆发<color=#FFD780FF><b>铃鸣·狩魔之刻</b></color>中，处于「寻猎」模式下的「诱巫饵铃」对敌人造成伤害后，若该次伤害对敌人触发了扩散反应，则还会在敌人面前召唤出一柄依据本次扩散反应进行元素转化的<b><span style=\"color:#FFD780FF\">「狩灾誓锤」</span></b>向其砸下，造成布伦妮攻击力150%的对应类型的元素伤害，该伤害视为元素爆发伤害。",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "振铃同心",
      "description": "当布伦妮使用发生过元素转化的<b><span style=\"color:#FFD780FF\">「狩灾誓锤」</span></b>命中敌人后，队伍中附近的其他角色将获得持续5秒的「振铃鼓舞」效果：普通攻击、重击、下落攻击、元素战技或元素爆发对敌人造成伤害时，基于其获得「振铃鼓舞」效果时，布伦妮攻击力超过2000的部分，提升本次攻击造成的伤害：每点攻击力都会使本次攻击造成的伤害提升0.025%，至多提升50%。",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "改装！敲敲打打！",
      "description": "合成角色天赋素材时，有10%概率额外产生一份地区相同的其他随机天赋素材，等阶与合成后获得的素材相同。",
      "level": 0
    }
  ],
