  "passives": [
    {
      "id": "eternal_speculation_engine",
      "name": "悠久的演算机关",
      "description": "<span style=\"color:#FFD780FF\">辉映·星超导</span>：施放元素战技<b><span style=\"color:#FFD780FF\">事象数式·游衍解析</span></b>时，若法洁欧的<color=#FFD780FF><b>解算功率</b></color>超过50点，则会在降低解算功率的同时，使向附近敌人发射的第二枚棱晶弹造成原本400%的伤害。<br/>此外，法洁欧的<span style=\"color:#FFD780FF\">解算功率</span>每降低10点，都会获得一层持续60秒的<span style=\"color:#FFD780FF\">改进战术</span>效果，该效果至多叠加10层。桑多涅处于<span style=\"color:#FFD780FF\">辉映·星超导</span>状态下施放元素爆发<b><span style=\"color:#FFD780FF\">事象数式·万理证毕</span></b>时，将会清除全部的改进战术层数，使负温聚能光束造成原本100%+清除层数*10%的伤害。",
      "level": 1
    },
