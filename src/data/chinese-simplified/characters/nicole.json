  "passives": [
    {
      "id": "methexis",
      "name": "分有",
      "description": "施放元素战技<color=#FFD780FF><b>圣言默示·未现之光</b></color>后的20秒内，尼可将持续「观测」队伍中自己的当前场上其他角色。受观测的角色持续处于场上3秒后，其拥有的<b><span style=\"color:#FFD780FF\">虚己之赐</span></b>效果将会升变为<b><span style=\"color:#FFD780FF\">圣祝之引</span></b>，使其额外提升300点攻击力；若受观测的角色为魔导角色，则<span style=\"color:#FFD780FF\">虚己之赐</span>效果将会直接升变为<span style=\"color:#FFD780FF\">圣祝之引</span>。<br/>除尼可外，其他角色拥有的<span style=\"color:#FFD780FF\">圣祝之引</span>将在退场时还原为<span style=\"color:#FFD780FF\">虚己之赐</span>。",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "慕善",
      "description": "队伍中附近的当前场上角色的元素伤害命中敌人后，尼可自己拥有的<b><span style=\"color:#FFD780FF\">虚己之赐</span></b>将会升变为<b><span style=\"color:#FFD780FF\">圣祝之引</span></b>，持续8秒。",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "静念",
      "description": "在提瓦特，不处于战斗状态下时，若已获得当前区域的寻宝罗盘，则尼可的重击将会转而施放「御使之引」：呼唤附近的仙灵指引道路，触发等同于当前区域寻宝罗盘的效果。<br/>该效果有5秒的冷却时间，且在秘境、征讨领域、深境螺旋中无效。",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "「不要惧怕，蒙眷爱的人之子呀」",
      "description": "队伍中自己的当前场上角色攻击命中敌人时，将会额外召唤出特殊的「奥迹造影·合一」，对敌人进行协同攻击，依据该角色的元素类型，造成对应元素范围伤害，该伤害相当于该角色攻击力的600%，并视为由该角色造成的伤害。<br/>该效果每6秒至多触发一次。",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "「我要教导你，指引你应走的路」",
      "description": "元素战技<color=#FFD780FF><b>圣言默示·未现之光</b></color>的效果获得强化：<b><span style=\"color:#FFD780FF\">虚己之赐</span></b>还会额外提升300点攻击力（不计入该效果的攻击力加成上限），<b><span style=\"color:#FFD780FF\">圣祝之引</span></b>还会依据角色的元素类型，使附近敌人的对应元素抗性降低25%，同元素类型的元素抗性降低效果不能叠加。<br/>此外，尼可施放元素战技<span style=\"color:#FFD780FF\">圣言默示·未现之光</span>时，也会为附近的当前场上角色赋予炽光护盾。",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "「为你身边的灯，为你前方的光」",
      "description": "元素战技<color=#FFD780FF><b>圣言默示·未现之光</b></color>的技能等级提高3级。<br/>至多提升至15级。",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "「向左或向右，无论你行往何方」",
      "description": "队伍中附近的角色拥有的<b><span style=\"color:#FFD780FF\">虚己之赐</span></b>升变为<b><span style=\"color:#FFD780FF\">圣祝之引</span></b>时，尼可还会为其赋予「先导之佑」效果，持续20秒，每名角色每16秒至多获得一次该效果。<br/>拥有「先导之佑」的角色的普通攻击、重击、下落攻击、元素战技与元素爆发造成的伤害提升，提升值相当于尼可攻击力的70%。该效果将在生效8次或持续时间结束时解除。<br/>同时命中多名敌人时，会依据命中敌人的数量消耗生效次数；队伍中具有「先导之佑」的角色，其生效次数单独计算。",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "「我就要有话对你说，在你身旁」",
      "description": "元素爆发<color=#FFD780FF><b>圣言默示·天路历程</b></color>的技能等级提高3级。<br/>至多提升至15级。",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "「这便是正确的道路，莫要彷徨」",
      "description": "尼可拥有的<b><span style=\"color:#FFD780FF\">虚己之赐</span></b>升变为<b><span style=\"color:#FFD780FF\">圣祝之引</span></b>时，队伍中附近的所有角色拥有的<span style=\"color:#FFD780FF\">虚己之赐</span>将会一同升变为<span style=\"color:#FFD780FF\">圣祝之引</span>。所有升变后的<span style=\"color:#FFD780FF\">圣祝之引</span>不再会还原为<span style=\"color:#FFD780FF\">虚己之赐</span>。<br/>此外，拥有<span style=\"color:#FFD780FF\">圣祝之引</span>的角色造成的伤害将无视敌人40%的防御力。",
