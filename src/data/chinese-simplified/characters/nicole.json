  "outfits": [
    {
      "id": 213100,
      "name": "解喻拟装",
      "description": "尼可的装扮款式。「…这是由那位在大地上流浪千年的天使，用语言和诗篇所织就的羽装。」开玩笑的，如果上面这段话说的是真的，有什么理由不每天换一套新的装扮呢？退一步说，就算有这种技术，为了不让茶会变成变装舞会，还是停止这种幻想吧。不管怎么说，毕竟高天的那位也没有禁止人们打扮成天使的模样嘛。",
      "isDefault": true,
      "characterName": "尼可",
      "characterId": 10000131,
      "filename_card": "UI_AvatarIcon_Costume_Card",
      "filename_iconCircle": "UI_AvatarIcon_Nicole_Circle"
