  "passives": [
    {
      "id": "verdict_and_punishment",
      "name": "Verdetto e punizione",
      "description": "Durante il Tripudio elementale <color=#FFD780FF><b>La campana rintocca! La caccia è aperta!</b></color>, dopo aver inflitto DAN tramite la Campana Ammaliastreghe in modalità Caccia, se tali DAN innescano un Turbinio su un avversario, viene evocato anche un <b><span style=\"color:#FFD780FF\">Martello Scacciamali</span></b> che infligge DAN pari a un 150% dell'ATT di Prune del tipo corrispondente alla Conversione elementale del Turbinio. Tali DAN sono considerati DAN da Tripudio elementale.",
      "level": 1
    },
    {
      "id": "tolling_synchronicity",
      "name": "Rintocchi sincronizzati",
      "description": "Dopo che Prune ha colpito un avversario con il <b><span style=\"color:#FFD780FF\">Martello Scacciamali</span></b> sottoposto a Conversione elementale, gli altri membri vicini del gruppo ottengono l'effetto Adunanza del rintocco per 5 s: quando gli attacchi normali, caricati o in picchiata, le abilità elementali o i Tripudi elementali infliggono DAN agli avversari, i DAN di tali attacchi aumentano in base alla quantità di ATT di Prune superiore a 2.000 nel momento in cui l'effetto Adunanza del rintocco si attiva. Ogni punto di ATT in eccesso aumenta tale iterazione di DAN di uno 0,025%, fino a un 50% massimo.",
      "level": 4
    },
    {
      "id": "tinkertink_clank_and_bang",
      "name": "Tin-tin, clang e bang!",
      "description": "Ha un 10% di probabilità di ottenere 1 materiale per talenti dei personaggi regionale (materiali di base esclusi) durante la creazione. La rarità è quella del materiale risultante.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1321,
      "id": "with_a_vow_to_rescue_the_journey_begins",
      "name": "Con un giuramento di soccorso, il viaggio ha inizio",
      "description": "Dopo aver colpito un avversario con il <b><span style=\"color:#FFD780FF\">Martello Scacciamali</span></b> sottoposto a Conversione elementale, Prune recupera 2 di energia. Quest'effetto può attivarsi una volta ogni 1,8 s.",
      "level": 1
    },
    {
      "_id": 1322,
      "id": "useful_for_cleaning_messy_baggage_elemental_powers_are_indeed",
      "name": "A ripulire i bagagli in disordine, servono i poteri elementali",
      "description": "Durante il Tripudio elementale <color=#FFD780FF><b>La campana rintocca! La caccia è aperta!</b></color>, quando la Campana Ammaliastreghe è in modalità Caccia, Prune ottiene l'effetto Caccia alla strega: l'ATT di Prune aumenta di un 10% e, quando la Campana Ammaliastreghe e il <b><span style=\"color:#FFD780FF\">Martello Scacciamali</span></b> sottoposto a Conversione elementale colpiscono un avversario, l'ATT di Prune aumenta di un ulteriore 5%, fino a un 40% massimo.<br/>L'iterazione originale del sopracitato effetto viene rimossa se si riutilizza La campana rintocca! La caccia è aperta! durante questo periodo di tempo.",
      "level": 2
    },
    {
      "_id": 1323,
      "id": "the_caravan_exits_the_mountain_pass_the_scenery_once_more_changed",
      "name": "Dal valico esce la carovana, muta ancora il paesaggio",
      "description": "Aumenta di 3 il livello di <color=#FFD780FF><b>La campana rintocca! La caccia è aperta!</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 3
    },
    {
      "_id": 1324,
      "id": "looking_back_following_the_wind_ones_shadow_still_halved",
      "name": "Volgendosi per seguire il vento, l'ombra ancora si dimezza",
      "description": "Dopo che il <b><span style=\"color:#FFD780FF\">Martello Scacciamali</span></b> sottoposto a Conversione elementale colpisce un avversario, esso rimbalza e piomba su un altro avversario nelle vicinanze, infliggendo DAN del tipo elementale corrispondente pari a un 80% dell'ATT.",
      "level": 4
    },
    {
      "_id": 1325,
      "id": "100_defeats_no_problem_tomorrow_we_go_again",
      "name": "Cento sconfitte? Nessun problema, ci riproveremo domani",
      "description": "Aumenta di 3 il livello di <color=#FFD780FF><b>Din-din-dan! Scampanio Scacciastreghe</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 5
    },
    {
      "_id": 1326,
      "id": "and_thats_the_story_share_it_with_your_friends",
      "name": "La storia è conclusa! Va' e condividila coi tuoi amici!",
      "description": "La durata della modalità Caccia della Campana Ammaliastreghe del Tripudio elementale <color=#FFD780FF><b>La campana rintocca! La caccia è aperta!</b></color> si estende di 4 s.<br/>Inoltre, quando i membri del gruppo dotati dell'effetto Adunanza del rintocco innescano una reazione elementale, Prune e gli altri personaggi attivi dotati del suddetto effetto ottengono un bonus di 350 ATT per 5 s.",
      "level": 6
    }
  ],
