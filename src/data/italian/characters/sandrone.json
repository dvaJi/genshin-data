  "passives": [
    {
      "id": "eternal_speculation_engine",
      "name": "Motore di calcolo eterno",
      "description": "Nello stato di <span style=\"color:#FFD780FF\">Splendore: Astroconduzione</span>, quando Sandrone utilizza l'abilità elementale <b><span style=\"color:#FFD780FF\">Formula fenomenale: Analisi differenziale</span></b>, se la <color=#FFD780FF><b>Potenza di decodifica</b></color> di Fagio è superiore a 50 punti, il secondo Colpo prismatico di Fagio scagliato agli avversari vicini infligge un 400% dei suoi DAN originali, comportando al contempo una riduzione della Potenza di decodifica.<br/>In più, per ogni 10 punti di <span style=\"color:#FFD780FF\">Potenza di decodifica</span> persi, Fagio ottiene 1 accumulo di <span style=\"color:#FFD780FF\">Tattiche sofisticate</span> per 60 s (massimo 10 accumuli). Quando Sandrone utilizza il Tripudio elementale <b><span style=\"color:#FFD780FF\">Formula fenomenale: Quod erat demonstrandum</span></b> mentre è nello stato di <span style=\"color:#FFD780FF\">Splendore: Astroconduzione</span>, tutti gli accumuli di Tattiche sofisticate vengono rimossi, permettendo al Raggio a inibizione convettiva di infliggere un 100% + (numero di accumuli rimossi) × 10% dei suoi DAN originali.",
      "level": 1
    },
    {
      "id": "a_ladys_code_of_conduct",
      "name": "Codice di condotta di una signora",
      "description": "Per ogni 100 di ATT, la maestria elementale di Sandrone aumenta di 8. L'aumento massimo ottenibile in questo modo è pari a 160.",
      "level": 4
    },
    {
      "id": "light_of_rationalisme",
      "name": "Luce del razionalismo",
      "description": "Quando i membri del gruppo innescano una reazione di Superconduzione, questa si trasforma in Astroconduzione, e i DAN base da Astroconduzione dei membri del gruppo vengono aumentati in base all'ATT di Sandrone. Per ogni 100 di ATT di Sandrone, i suddetti DAN base aumentano di uno 0,7%, fino a un 14% massimo.<br/>Inoltre, quando Sandrone si trova in un <b><span style=\"color:#FFD780FF\">Campo astropolare</span></b>, entra nello stato di <span style=\"color:#FFD780FF\">Splendore: Astroconduzione</span>.",
      "level": 0
    },
    {
      "id": "a_caucus_prelude_and_a_long_tale",
      "name": "Preludio del caucus e un lungo racconto",
      "description": "Quando Sandrone è nel gruppo, ottieni ricompense aggiuntive sotto forma di spuntini dopo aver completato gli incarichi giornalieri di Katheryne.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1331,
      "id": "morrow_after_the_golden_dusk",
      "name": "L'indomani di un tramonto dorato",
      "description": "Quando è in modalità <color=#FFD780FF><b>Decodifica</b></color>, il tasso di aumento della <color=#FFD780FF><b>Potenza di decodifica</b></color> di Fagio si riduce di un 50%, e tutti i membri del gruppo infliggono un 30% di DAN da Astroconduzione in più.",
      "level": 1
    },
    {
      "_id": 1332,
      "id": "an_heiress_gazed_into_the_lookingglass",
      "name": "Attraverso lo specchio e quel che l'ereditiera vi trovò",
      "description": "Nello stato di <span style=\"color:#FFD780FF\">Splendore: Astroconduzione</span>, i DAN da CRIT dei Raggi condensati degli attacchi caricati aumentano di un 40%. Inoltre, a ogni raggio sparato, i DAN da CRIT inflitti da tutti i Raggi condensati sparati durante la modalità <color=#FFD780FF><b>Decodifica</b></color> aumentano di un ulteriore 20%. Massimo 3 accumuli.",
      "level": 2
    },
    {
      "_id": 1333,
      "id": "refuse_the_wake_of_dusk_the_moonlit_yoke",
      "name": "Rifiuta il risveglio del crepuscolo, il giogo illuminato dalla luna",
      "description": "Aumenta di 3 il livello di <b><span style=\"color:#FFD780FF\">Formula fenomenale: Proposizione autoevidente</span></b>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 3
    },
    {
      "_id": 1334,
      "id": "in_knowledge_lies_the_worlds_true_ground",
      "name": "La conoscenza è il vero fondamento del mondo",
      "description": "Quando Sandrone infligge DAN da Astroconduzione a un avversario, evoca anche un Cannone a risonanza prismatica aggiuntivo per sparare un attacco coordinato che infligge <span style=\"color:#99FFFFFF\">DAN da Cryo</span> pari a un 125% del suo ATT. Tali DAN sono considerati DAN da Astroconduzione. Quest'effetto può verificarsi una volta ogni 4 s.",
      "level": 4
    },
    {
      "_id": 1335,
      "id": "of_all_beside_she_takes_no_part",
      "name": "Di tutto ciò che la circonda, lei non fa parte",
      "description": "Aumenta di 3 il livello di <b><span style=\"color:#FFD780FF\">Formula fenomenale: Quod erat demonstrandum</span></b>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 5
    },
    {
      "_id": 1336,
      "id": "narcissus_wakes_her_eyes_upon_the_dawn",
      "name": "Narcissus si desta, i suoi occhi sull'alba",
      "description": "Mentre è nella modalità <color=#FFD780FF><b>Decodifica</b></color>, quando Fagio spara un Raggio condensato per la terza volta, quest'ultimo viene convertito in un più potente <span style=\"color:#FFD780FF\">Raggio a grappolo condensato</span> che spara continuamente. Quest'ultimo infligge fino a 4 iterazioni aggiuntive di <span style=\"color:#99FFFFFF\">DAN da Cryo ad area</span>, pari a un 100% dell'ATT di Sandrone, oltre a qualsiasi raggio originale successivo sparato.<br/>Nello stato di <span style=\"color:#FFD780FF\">Splendore: Astroconduzione</span>, invece, il <span style=\"color:#FFD780FF\">Raggio a grappolo condensato</span> infligge 4 iterazioni aggiuntive di <span style=\"color:#99FFFFFF\">DAN da Cryo ad area</span>, pari a un 80% dell'ATT di Sandrone, considerati come DAN da Astroconduzione.<br/>Inoltre, tutti i DAN da Astroconduzione inflitti da Sandrone vengono <b><span style=\"color:#FFD780FF\">innalzati</span></b> di un 20%.",
      "level": 6
    }
  ],
