  "passives": [
    {
      "id": "field_observation_notes",
      "name": "Note di osservazione sul campo",
      "description": "Quando Lumi è in campo, la <span style=\"color:#FFE699FF\">RES a Geo</span> degli avversari vicini a lei diminuisce di un 15%.<br/><br/>Quando <span style=\"color:#FFD780FF\">Presagio lunare: Barlume ascendente</span> è attivo, l'abilità elementale <color=#FFD780FF><b>Contromisura: Grido di battaglia di Lumi!</b></color> e il Tripudio elementale <color=#FFD780FF><b>Promemoria: Guida di sopravvivenza in condizioni estreme</b></color> di Linnea vengono potenziati. Dopo aver evocato Lumi, la <span style=\"color:#FFE699FF\">RES a Geo</span> degli avversari vicino a lei diminuisce di un ulteriore 15%.",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "Diario naturalistico universale",
      "description": "Linnea aumenta la maestria elementale di alcuni personaggi del tuo gruppo in base a un 5% della sua DIF e a seconda del personaggio attivo attuale. Se il tuo personaggio attivo:<br/>· è un personaggio con Presagio lunare, la sua maestria elementale aumenta;<br/>· non è un personaggio con Presagio lunare, la maestria elementale di Linnea aumenta.",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "Benedizione del Presagio lunare: Studio dell'habitat",
      "description": "Quando un membro del gruppo innesca una reazione di Cristallizzazione di Hydro, questa si converte in una reazione di Cristallizzazione lunare, i cui DAN base aumentano di uno 0,7% per ogni 100 di DIF di Linnea, fino a un 14% massimo.<br/><br/>Inoltre, quando Linnea è nel gruppo, il <span style=\"color:#FFD780FF\">Presagio lunare</span> del gruppo aumenta di 1 livello.",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "Avventuriera esperta",
      "description": "Quando Linnea non è in un combattimento, il tempo di carica del suo <span style=\"color:#FFD780FF\">attacco mirato</span> è notevolmente ridotto, il che le permette di scoccare una <span style=\"color:#FFD780FF\">Freccia rapida ultrapratica</span>. Si verificano effetti diversi a seconda dei bersagli colpiti.<br/>· Animali specifici: la <span style=\"color:#FFD780FF\">Freccia rapida ultrapratica</span> si trasforma in una speciale \"Rete\" in grado di catturare l'essenza e la forma di tali animali, usandole come tramite per manifestarne nuovamente la forma fisica. La \"Rete\" può essere utilizzata solo per un numero limitato di volte a settimana.<br/>· Giacimenti di minerali usati nella forgiatura: Linnea invia Lumi, che colpisce rapidamente il minerale indicato dalla <span style=\"color:#FFD780FF\">Freccia rapida ultrapratica</span>, raccogliendo poi il minerale estratto. Se Lumi non è in campo, Linnea la evoca brevemente per farle raccogliere i minerali.<br/><br/>I DAN inflitti agli avversari dalla <span style=\"color:#FFD780FF\">Freccia rapida ultrapratica</span> di Linnea sono ridotti a un 20% della sua freccia caricata originale. Inoltre, dopo aver scoccato un certo numero di <span style=\"color:#FFD780FF\">Frecce rapide ultrapratiche</span> in un breve periodo di tempo, Linnea avrà bisogno di una pausa temporanea prima di poterle utilizzare di nuovo.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1301,
      "id": "provisional_classification",
      "name": "Classificazione provvisoria",
      "description": "Quando usa l'abilità elementale <color=#FFD780FF><b>Contromisura: Grido di battaglia di Lumi!</b></color> o quando si attiva Armonia della Gabbia lunare, Linnea ottiene 6 accumuli dell'effetto <span style=\"color:#FFD780FF\">Catalogo da campo</span> per 10 s, per un massimo di 18 accumuli. Quando i membri vicini del gruppo infliggono DAN da reazione di Cristallizzazione lunare, consumano 1 accumulo di Catalogo da campo per aumentare i DAN inflitti. L'aumento dei DAN è pari a un 75% della DIF di Linnea.<br/>Inoltre, quando Lumi usa <span style=\"color:#FFD780FF\">Polverizzazione devastante</span> nella sua <color=#FFD780FF><b>Forma superpotente finale</b></color>, Linnea può consumare fino a 5 accumuli di Catalogo da campo, aumentando i DAN inflitti di un 150% della DIF di Linnea per ogni accumulo consumato.",
      "level": 1
    },
    {
      "_id": 1302,
      "id": "tidings_of_joy_and_sorrow",
      "name": "Notizie di gioia e dolore",
      "description": "Entro 8 s dall'attivazione di Armonia della Gabbia lunare, i DAN da CRIT di tutti i membri del gruppo di <span style=\"color:#80C0FFFF\">Hydro</span> e di <span style=\"color:#FFE699FF\">Geo</span> aumentano di un 40%. Inoltre, quando Lumi usa <span style=\"color:#FFD780FF\">Polverizzazione devastante</span> nella sua <color=#FFD780FF><b>Forma superpotente finale</b></color>, i DAN da CRIT di tale attacco aumentano di un ulteriore 150%.<br/><br/>Quando <span style=\"color:#FFD780FF\">Presagio lunare: Barlume ascendente</span> è attivo, se Lumi usa il <span style=\"color:#FFD780FF\">Martello sovraccarico pesante</span> nella sua <color=#FFD780FF><b>Forma superpotente</b></color> o <span style=\"color:#FFD780FF\">Polverizzazione devastante</span> nella sua Forma superpotente finale, si innesca un'iterazione di Armonia della Gabbia lunare, durante la quale gli elementi dei personaggi di <span style=\"color:#80C0FFFF\">Hydro</span> e di <span style=\"color:#FFE699FF\">Geo</span> presenti nel gruppo vengono considerati applicati alla reazione.",
      "level": 2
    },
    {
      "_id": 1303,
      "id": "eventful_log_page",
      "name": "Pagina del registro ricca di eventi",
      "description": "Aumenta di 3 il livello di <color=#FFD780FF><b>Contromisura: Grido di battaglia di Lumi!</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 3
    },
    {
      "_id": 1304,
      "id": "expert_instinct",
      "name": "Istinto dell'esperta",
      "description": "Entro 5 s dall'attivazione di Armonia della Gabbia lunare, la DIF di Linnea e quella del tuo personaggio attivo attuale aumentano di un 25%. Quando Linnea è in campo, l'effetto di aumento della DIF può accumularsi.",
      "level": 4
    },
    {
      "_id": 1305,
      "id": "fairylands_farewell_gift",
      "name": "Dono d'addio della Terra delle Fate",
      "description": "Aumenta di 3 il livello del Tripudio elementale <color=#FFD780FF><b>Promemoria: Guida di sopravvivenza in condizioni estreme</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 5
    },
    {
      "_id": 1306,
      "id": "golden_beagles_dream",
      "name": "Sogno del Bracco dorato",
      "description": "Potenzia gli effetti della costellazione <span style=\"color:#FFD780FF\">Classificazione provvisoria</span>. Quando si sprigiona l'abilità elementale <color=#FFD780FF><b>Contromisura: Grido di battaglia di Lumi!</b></color> o quando si attiva Armonia della Gabbia lunare, Linnea ottiene direttamente il numero massimo di accumuli di <span style=\"color:#FFD780FF\">Catalogo da campo</span>. Nel consumare <span style=\"color:#FFD780FF\">Catalogo da campo</span>, consuma due volte il numero originale di accumuli, di modo che l'aumento dei DAN venga incrementato a un 150% del valore originale.<br/><br/>Quando <span style=\"color:#FFD780FF\">Presagio lunare: Barlume ascendente</span> è attivo, i DAN da Cristallizzazione lunare inflitti dai membri del gruppo vicini vengono <b><span style=\"color:#FFD780FF\">innalzati</span></b> di un 25%.",
      "level": 6
    }
  ],
