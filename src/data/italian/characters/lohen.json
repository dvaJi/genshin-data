  "passives": [
    {
      "id": "moratorium_on_questioning",
      "name": "Facoltà di non rispondere",
      "description": "Quando i membri vicini del gruppo accumulano <b><span style=\"color:#FFD780FF\">Voglia di vincere</span></b> per Lohen infliggendo DAN mentre è in modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b>, se tali DAN non sono inferiori a un 3.000% dell'ATT di base di Lohen, quest'ultimo riceve 60 punti <span style=\"color:#FFD780FF\">Voglia di vincere</span> aggiuntivi.",
      "level": 1
    },
    {
      "id": "flippant_masterpiece",
      "name": "Capolavoro frivolo",
      "description": "Mentre è in modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b>, per 8 s dopo che un altro membro vicino del gruppo ha innescato una <span style=\"color:#99FFFFFF\">reazione di Cryo</span>, l'ATT di Lohen e quello del suddetto membro aumentano di un 15%.",
      "level": 4
    },
    {
      "id": "when_the_mood_strikes",
      "name": "Umore giusto",
      "description": "Quando usa la sua abilità elementale <span style=\"color:#FFD780FF\">Colpo imprevisto</span>, Lohen ottiene Buonumore per 9 s, che aumenta di 1 il livello della suddetta abilità.<br/>Quando sprigiona un'abilità elementale, se il livello di attacco normale, abilità elementale o Tripudio elementale di qualsiasi altro membro del gruppo è maggiore o uguale al livello dell'abilità elementale di Lohen, la durata della suddetta iterazione di Buonumore si estende di ulteriori 6 s.<br/>Lohen può ottenere Buonumore una volta ogni 18 s.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1291,
      "id": "o_breezes_that_so_oft_bear_sorrowful_lament",
      "name": "O brezze, sempre dal dolore afflitte",
      "description": "Il limite massimo di <b><span style=\"color:#FFD780FF\">Voglia di vincere</span></b> di Lohen aumenta a un 300% del suo valore originale.<br/>Inoltre, quando gli altri membri vicini del gruppo infliggono DAN mentre Lohen è in modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b>, accumulano un 500% della quantità originale di <span style=\"color:#FFD780FF\">Voglia di vincere</span> per Lohen.",
      "level": 1
    },
    {
      "_id": 1292,
      "id": "in_flight_i_strike_whatever_flies",
      "name": "Solcando i cieli, in volo ferisco",
      "description": "Quando è in modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b>, dopo aver colpito un avversario con l'abilità elementale speciale <b><span style=\"color:#FFD780FF\">Nelle ossa e nell'anima</span></b> o aver sprigionato il Tripudio elementale <span style=\"color:#FFD780FF\">Giudizio manifesto</span>, Lohen ottiene Lama Scacciamali per 4 s: la volta successiva che colpisce un avversario con un attacco normale o caricato mentre è in modalità Colpo da maestro, Lohen sferra un colpo aggiuntivo che infligge <span style=\"color:#99FFFFFF\">DAN da Cryo ad area</span> pari a un 500% del suo ATT e aumenta la maestria elementale degli altri membri vicini del gruppo di 200 per 8 s. Lama Scacciamali può essere attivata una volta ogni 4 s.",
      "level": 2
    },
    {
      "_id": 1293,
      "id": "only_the_spear_that_wounds_can_heal",
      "name": "Una piaga che solo la lancia può sanare",
      "description": "Aumenta di 3 il livello di <color=#FFD780FF><b>Colpo imprevisto</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 3
    },
    {
      "_id": 1294,
      "id": "radiant_love_laughing_death",
      "name": "Risplende l'amore, sogghigna la morte",
      "description": "Quando Lohen sprigiona il Tripudio elementale <span style=\"color:#FFD780FF\">Giudizio manifesto</span> mentre è in modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b>, la sua <b><span style=\"color:#FFD780FF\">Voglia di vincere</span></b> raggiunge il valore massimo, permettendo all'attuale iterazione del Tripudio elementale di ottenere l'aumento di DAN più alto possibile.<br/><br/>Inoltre, quando Lohen passa alla modalità <span style=\"color:#FFD780FF\">Colpo da maestro</span>, si verificano i seguenti effetti in base alla sua quantità di energia elementale.<br/>· Quando non è al massimo, l'energia elementale di Lohen si ripristina di 15.<br/>· Quando è al massimo, se nei successivi 15 s Lohen scatena il Tripudio elementale <span style=\"color:#FFD780FF\">Giudizio manifesto</span>, l'energia elementale di Lohen si ripristina di 15.",
      "level": 4
    },
    {
      "_id": 1295,
      "id": "never_ask_nor_trouble_you_to_know",
      "name": "Non fare domande e non darti pensiero",
      "description": "Aumenta di 3 il livello di <color=#FFD780FF><b>Giudizio manifesto</b></color>.<br/>Il livello di potenziamento massimo è 15.",
      "level": 5
    },
    {
      "_id": 1296,
      "id": "to_drown_to_sink_unconscious_supreme_joy",
      "name": "Annegare m'è dolce in questo mare",
      "description": "Usare l'abilità elementale speciale <b><span style=\"color:#FFD780FF\">Nelle ossa e nell'anima</span></b> e colpire con essa un avversario, o sprigionare il Tripudio elementale <span style=\"color:#FFD780FF\">Giudizio manifesto</span> mentre la modalità <b><span style=\"color:#FFD780FF\">Colpo da maestro</span></b> è attiva, non consuma <b><span style=\"color:#FFD780FF\">Voglia di vincere</span></b>, bensì conferisce a Lohen la quantità massima di <b><span style=\"color:#FFD780FF\">Gioia</span></b>; se Lohen colpisce un avversario con il successivo uso dell'abilità elementale speciale <span style=\"color:#FFD780FF\">Nelle ossa e nell'anima</span>, la durata dell'attuale iterazione di <span style=\"color:#FFD780FF\">Colpo da maestro</span> si estende di 1,25 s. Quest'effetto può attivarsi una volta ogni 7 s.<br/>In aggiunta, i DAN da CRIT di tutti i DAN sopra descritti aumentano di un 175%, e il numero di volte che Lohen può sprigionare <span style=\"color:#FFD780FF\">Nelle ossa e nell'anima</span> durante l'attuale iterazione di <span style=\"color:#FFD780FF\">Colpo da maestro</span> aumenta di 2.",
      "level": 6
    }
