  "passives": [
    {
      "id": "dawn_winds_march",
      "name": "Dawn Wind's March",
      "description": "Saat ada Karakter <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span>, atau <span style=\"color:#99FFFFFF\">Cryo</span> dalam party, untuk setiap 1.000 poin ATK yang dimiliki Varka, ia akan mendapatkan <span style=\"color:#80FFD7FF\">10%</span> Anemo DMG Bonus dan Elemental DMG Bonus untuk jenis elemen yang sesuai berdasarkan urutan prioritas elemen yang disebutkan di atas (maksimum 1 jenis elemen dari elemen yang disebutkan di atas yang bisa diperoleh dengan cara ini), hingga maksimum 25%.<br/><br/>Selain itu, saat ada setidaknya 2 Karakter <span style=\"color:#80FFD7FF\">Anemo</span> dalam party, atau ada setidaknya 2 Karakter <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span>, atau <span style=\"color:#99FFFFFF\">Cryo</span> dengan jenis elemen yang sama, maka Normal Attack, Charged Attack, Charged Attack Khusus <span style=\"color:#FFD780FF\">Azure Devour</span>, dan Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Four Winds' Ascension</span></b> Varka yang dilancarkan dalam mode <b><span style=\"color:#FFD780FF\">Sturm und Drang</span></b> akan mengakibatkan 140% dari DMG awalnya. Jika party memiliki setidaknya 2 Karakter <span style=\"color:#80FFD7FF\">Anemo</span> dan setidaknya 2 Karakter <span style=\"color:#FF9999FF\">Pyro</span>, <span style=\"color:#80C0FFFF\">Hydro</span>, <span style=\"color:#FFACFFFF\">Electro</span>, atau <span style=\"color:#99FFFFFF\">Cryo</span> dengan jenis elemen yang sama, maka efek di atas meningkat menjadi 220%.",
      "level": 1
    },
    {
      "id": "winds_vanguard",
      "name": "Wind's Vanguard",
      "description": "Saat Karakter party di sekitar memicu reaksi Swirl, Varka mendapatkan 1 lapis <span style=\"color:#FFD780FF\">Azure Fang's Oath</span> yang akan meningkatkan DMG Normal Attack, Charged Attack, Charged Attack Khusus <span style=\"color:#FFD780FF\">Azure Devour</span>, dan Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Four Winds' Ascension</span></b> milik Varka sebesar 7,5% selama 8 detik. Efek ini dapat ditumpuk sampai 4 lapis. Setiap Karakter dapat memberikan 1 lapis <span style=\"color:#FFD780FF\">Azure Fang's Oath</span> untuk Varka sekali setiap detik dengan cara ini.",
      "level": 4
    },
    {
      "id": "homebound_winds_paean",
      "name": "Homebound Wind's Paean",
      "description": "Untuk setiap 1 Karakter Mondstadt dalam party, CD untuk Elemental Skill Mode Tahan <span style=\"color:#FFD780FF\">Windbound Execution</span> berkurang 5%.<br/>Efek ini tidak aktif dalam Domain, Trounce Domain, atau Spiral Abyss.",
      "level": 0
    }
