    {
      "_id": 1281,
      "id": "come_friend_let_us_dance_beneath_the_moons_soft_glow",
      "name": "\"Come, Friend, Let Us Dance Beneath the Moon's Soft Glow\"",
      "description": "Saat Varka beralih ke mode <b><span style=\"color:#FFD780FF\">Sturm und Drang</span></b>, akan mendapatkan 1 kali kesempatan penggunaan Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Four Winds' Ascension</span></b>.<br/>Selain itu, setelah berganti ke mode <span style=\"color:#FFD780FF\">Sturm und Drang</span>, Varka akan mendapatkan efek <span style=\"color:#FFD780FF\">Lyrical Libation</span>: Saat melancarkan Elemental Skill Khusus <span style=\"color:#FFD780FF\">Four Winds' Ascension</span> atau melancarkan Charged Attack khusus <span style=\"color:#FFD780FF\">Azure Devour</span>, Varka akan mengonsumsi efek ini dan membuat <span style=\"color:#FFD780FF\">Four Winds' Ascension</span> atau <span style=\"color:#FFD780FF\">Azure Devour</span> mengakibatkan 200% dari DMG awalnya.",
      "level": 1
    },
    {
      "_id": 1282,
      "id": "when_dawn_breaks_our_journey_shall_take_flight",
      "name": "\"When Dawn Breaks, Our Journey Shall Take Flight\"",
      "description": "Saat melancarkan Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Four Winds' Ascension</span></b> atau Charged Attack Khusus <span style=\"color:#FFD780FF\">Azure Devour</span>, Varka akan melancarkan satu kali serangan tambahan yang mengakibatkan <span style=\"color:#80FFD7FF\">Anemo DMG Area</span> sebesar 800% ATK-nya.",
      "level": 2
    },
    {
      "_id": 1283,
      "id": "o_friend_quaff_not_the_bitter_wine_that_brings_tears_of_woe",
      "name": "\"O Friend, Quaff Not the Bitter Wine That Brings Tears of Woe\"",
      "description": "Meningkatkan 3 level Elemental Skill <color=#FFD780FF><b>Windbound Execution</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 3
    },
    {
      "_id": 1284,
      "id": "for_none_may_take_from_us_our_freedom_of_song",
      "name": "\"For None May Take From Us Our Freedom of Song\"",
      "description": "Saat Varka memicu reaksi Swirl, seluruh Karakter party di sekitar akan mendapatkan 20% <span style=\"color:#80FFD7FF\">Anemo DMG Bonus</span> dan juga Elemental DMG Bonus untuk jenis elemen yang terlibat dalam reaksi tersebut, berlangsung selama 10 detik.",
      "level": 4
    },
    {
      "_id": 1285,
      "id": "fill_high_the_cup_with_fine_wine_for_tyrants_come_and_go",
      "name": "\"Fill High the Cup With Fine Wine, for Tyrants Come and Go\"",
      "description": "Meningkatkan 3 level Elemental Burst <color=#FFD780FF><b>Northwind Avatar</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 5
    },
    {
      "_id": 1286,
      "id": "beloved_mondstadt_steadfast_you_shall_shine",
      "name": "\"Beloved Mondstadt, Steadfast You Shall Shine\"",
      "description": "Mode <b><span style=\"color:#FFD780FF\">Sturm und Drang</span></b> diperkuat:<br/>·Selama beberapa saat setelah melancarkan Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Four Winds' Ascension</span></b>, Varka dapat menekan Elemental Skill atau menahan tombol Normal Attack untuk melancarkan satu kali Charged Attack Khusus <span style=\"color:#FFD780FF\">Azure Devour</span> tambahan tanpa mengonsumsi jumlah penggunaan Four Winds' Ascension.<br/>·Selama beberapa saat setelah melancarkan Charged Attack Khusus <span style=\"color:#FFD780FF\">Azure Devour</span>, Varka bisa menekan Elemental Skill untuk melancarkan satu kali <span style=\"color:#FFD780FF\">Four Winds' Ascension</span> tambahan tanpa mengonsumsi jumlah penggunaan Four Winds' Ascension.<br/>Charged Attack Khusus tambahan, Azure Devour, atau Elemental Skill Khusus tambahan, Four Winds' Ascension yang dilancarkan dengan cara di atas tidak akan dapat memicu efek di atas lagi.<br/><br/>Selain itu, efek <span style=\"color:#FFD780FF\">Azure Fang's Oath</span> dari Talenta Ascension <color=#FFD780FF><b>Wind's Vanguard</b></color> diperkuat: Setiap lapis <span style=\"color:#FFD780FF\">Azure Fang's Oath</span> akan meningkatkan 20% CRIT DMG Varka.",
      "level": 6
    }
  ],
