  "passives": [
    {
      "id": "methexis",
      "name": "Methexis",
      "description": "Selama 20 detik setelah melancarkan Elemental Skill <color=#FFD780FF><b>Revelation: Uncreated Light</b></color>, Nicole akan terus \"mengobservasi\" Karakter aktif lain dalam party. Setelah Karakter yang diobservasi berada di medan pertempuran selama 3 detik, efek <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> miliknya akan meningkat menjadi <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b> dan memberikan tambahan 300 poin ATK. Jika Karakter yang diobservasi adalah Karakter Hexerei, maka efek <span style=\"color:#FFD780FF\">Grace of Kenosis</span> akan langsung ditingkatkan menjadi <span style=\"color:#FFD780FF\">Guidance of Theosis</span>.<br/>Selain Nicole, <span style=\"color:#FFD780FF\">Guidance of Theosis</span> yang dimiliki Karakter lain akan langsung kembali menjadi <span style=\"color:#FFD780FF\">Grace of Kenosis</span> saat Karakter itu meninggalkan medan pertempuran.",
      "level": 1
    },
    {
      "id": "philokalia",
      "name": "Philokalia",
      "description": "Saat Elemental DMG anggota party aktif di sekitar mengenai musuh, <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> yang dimiliki Nicole sendiri akan meningkat menjadi <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b> selama 8 detik.",
      "level": 4
    },
    {
      "id": "nepsis",
      "name": "Nepsis",
      "description": "Saat tidak dalam kondisi bertempur dan sudah memperoleh Treasure Compass untuk area yang sedang dijelajahi di Teyvat, Charged Attack Nicole akan dikonversi menjadi \"Emissarial Guidance\": Memanggil Seelie terdekat untuk memberi petunjuk, memicu efek yang sama dengan Treasure Compass untuk area tersebut.<br/>Efek ini memiliki cooldown selama 5 detik, dan tidak berlaku di Domain, Domain Trounce, dan Spiral Abyss.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1311,
      "id": "do_not_be_afraid_child_who_is_loved",
      "name": "\"Do Not Be Afraid, Child Who Is Loved\"",
      "description": "Saat serangan Karakter aktif sendiri di party mengenai musuh, akan memanggil \"Arcane Projection: Unity\" spesial tambahan untuk melancarkan serangan terkoordinasi terhadap musuh. Serangan ini akan mengakibatkan Elemental DMG Area yang sesuai dengan jenis elemen Karakter tersebut dan DMG-nya didasarkan pada 600% ATK Karakter tersebut, dan dianggap sebagai DMG yang diakibatkan oleh Karakter tersebut.<br/>Efek ini dapat terpicu sekali setiap 6 detik.",
      "level": 1
    },
    {
      "_id": 1312,
      "id": "i_will_guide_you_and_show_you_the_path_you_should_tread",
      "name": "\"I Will Guide You and Show You the Path You Should Tread\"",
      "description": "Efek Elemental Skill <color=#FFD780FF><b>Revelation: Uncreated Light</b></color> diperkuat: <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> juga akan meningkatkan ATK sebesar 300 poin tambahan (tidak termasuk dalam batas maksimum peningkatan ATK efek ini), <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b> juga akan mengurangi Elemental RES musuh di sekitar sebesar 25% berdasarkan jenis elemen Karakter, efek pengurangan Elemental RES dari jenis elemen yang sama tidak dapat ditumpuk.<br/>Selain itu, saat Nicole melancarkan Elemental Skill <span style=\"color:#FFD780FF\">Revelation: Uncreated Light</span>, Karakter aktif di sekitar akan mendapatkan Shield of Blazing Light.",
      "level": 2
    },
    {
      "_id": 1313,
      "id": "a_lamp_by_your_side_a_light_to_shine_the_way",
      "name": "\"A Lamp by Your Side, A Light to Shine the Way\"",
      "description": "Meningkatkan 3 level Elemental Skill <color=#FFD780FF><b>Revelation: Uncreated Light</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 3
    },
    {
      "_id": 1314,
      "id": "whether_left_or_right_no_matter_which_way_you_turn",
      "name": "\"Whether Left or Right, No Matter Which Way You Turn\"",
      "description": "Saat efek <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> yang dimiliki Karakter party di sekitar Nicole meningkat menjadi <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b>, Nicole juga akan memberikan efek \"Pathfinder's Blessing\" kepada mereka selama 20 detik. Setiap Karakter dapat memperoleh efek ini maksimum satu kali setiap 16 detik.<br/>Saat memiliki Pathfinder's Blessing, DMG yang diakibatkan oleh Normal Attack, Charged Attack, Plunging Attack, Elemental Skill, dan Elemental Burst Karakter akan meningkat sebesar 70% dari ATK Nicole. Efek ini akan berakhir setelah terpicu 8 kali atau saat durasinya berakhir.<br/>Saat mengenai beberapa musuh sekaligus, jumlah terpicunya efek akan mengikuti jumlah musuh yang terkena. Jumlah terpicunya efek Pathfinder's Blessing untuk setiap Karakter party dihitung secara terpisah.",
      "level": 4
    },
    {
      "_id": 1315,
      "id": "you_will_hear_my_voice_beside_you",
      "name": "\"You Will Hear My Voice Beside You\"",
      "description": "Meningkatkan 3 level Elemental Burst <color=#FFD780FF><b>Revelation: Ladder of Divine Ascent</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 5
    },
    {
      "_id": 1316,
      "id": "this_is_the_path_walk_it_without_delay",
      "name": "\"This Is the Path, Walk It Without Delay\"",
      "description": "Saat <b><span style=\"color:#FFD780FF\">Grace of Kenosis</span></b> yang dimiliki Nicole meningkat menjadi <b><span style=\"color:#FFD780FF\">Guidance of Theosis</span></b>, <span style=\"color:#FFD780FF\">Grace of Kenosis</span> yang dimiliki seluruh anggota party di sekitar juga akan meningkat menjadi <span style=\"color:#FFD780FF\">Guidance of Theosis</span> secara bersamaan. Seluruh <span style=\"color:#FFD780FF\">Guidance of Theosis</span> yang mengalami peningkatan tidak akan berubah kembali menjadi <span style=\"color:#FFD780FF\">Grace of Kenosis</span>.<br/>Selain itu, Karakter yang memiliki <span style=\"color:#FFD780FF\">Guidance of Theosis</span> akan mengabaikan 40% DEF musuh saat mengakibatkan DMG.",
      "level": 6
    }
  ],
