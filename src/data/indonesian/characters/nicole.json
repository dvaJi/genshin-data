  "outfits": [
    {
      "id": 213100,
      "name": "Mimetic Interpretation",
      "description": "Model pakaian Nicole. \"... Ini adalah jubah bersayap yang ditenun dari kata-kata dan syair malaikat yang mengembara di bumi selama ribuan tahun.\" Ah, hanya bercanda. Kalau itu benar, kenapa tidak ganti kostum baru setiap hari? Seandainya teknologi seperti itu memang ada, lebih baik jangan berfantasi lebih jauh lagi, demi mencegah pesta teh berubah jadi pesta kostum. Bagaimanapun juga, dia yang di atas langit pun tidak melarang orang untuk berdandan seperti malaikat.",
      "isDefault": true,
      "characterName": "Nicole",
      "characterId": 10000131,
      "filename_card": "UI_AvatarIcon_Costume_Card",
      "filename_iconCircle": "UI_AvatarIcon_Nicole_Circle"
    }
