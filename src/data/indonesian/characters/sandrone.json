  "passives": [
    {
      "id": "eternal_speculation_engine",
      "name": "Eternal Speculation Engine",
      "description": "<span style=\"color:#FFD780FF\">Radiance: Stellar-Conduct</span>: Saat melancarkan Elemental Skill <b><span style=\"color:#FFD780FF\">Formule Phenomenale: Differential Analysis</span></b>, jika <color=#FFD780FF><b>Decoding Power</b> </color>Fagio melebihi 50 poin, maka Prism Shot kedua yang ditembakkan ke musuh di sekitar akan mengakibatkan 400% DMG dari DMG aslinya seiring berkurangnya Decoding Power Fagio.<br/>Selain itu, setiap kali <span style=\"color:#FFD780FF\">Decoding Power</span> Fagio berkurang 10 poin, ia akan memperoleh 1 lapis efek <span style=\"color:#FFD780FF\">Refined Tactics</span> yang bertahan selama 60 detik. Efek ini dapat ditumpuk sampai 10 lapis. Saat Sandrone melancarkan Elemental Burst <b><span style=\"color:#FFD780FF\">Formule Phenomenale: Q.E.D</span></b> dalam status <span style=\"color:#FFD780FF\">Radiance: Stellar-Conduct</span>, semua lapisan Refined Tactics akan terhapus dan membuat Convective Inhibition Ray mengakibatkan DMG sebesar 100% + (jumlah lapisan yang dihapus ×10%) dari DMG aslinya.",
      "level": 1
    },
    {
      "id": "a_ladys_code_of_conduct",
      "name": "A Lady's Code of Conduct",
      "description": "Meningkatkan Elemental Mastery Sandrone berdasarkan ATK-nya. Setiap 100 poin ATK akan meningkatkan Elemental Mastery Sandrone sebesar 8 poin. Maksimal dapat meningkatkan 160 poin Elemental Mastery dengan cara ini.",
      "level": 4
    },
    {
      "id": "light_of_rationalisme",
      "name": "Light of Rationalisme",
      "description": "Saat Karakter di dalam party memicu reaksi Superconduct, reaksi ini akan diubah menjadi reaksi Stellar-Conduct. DMG dasar reaksi Stellar-Conduct Karakter di dalam party meningkat berdasarkan ATK Sandrone: Untuk setiap 100 poin ATK, DMG dasarnya meningkat 0,7%, dapat meningkat hingga maksimum 14% dengan cara ini.<br/>Selain itu, saat Sandrone berada dalam area <b><span style=\"color:#FFD780FF\">Polestar Field</span></b>, ia akan memasuki status <span style=\"color:#FFD780FF\">Radiance: Stellar-Conduct</span>.",
      "level": 0
    },
    {
      "id": "a_caucus_prelude_and_a_long_tale",
      "name": "A Caucus Prelude and a Long Tale",
      "description": "Saat Sandrone berada dalam party, kamu akan mendapatkan hadiah camilan tambahan saat menyerahkan Misi Harian ke Katheryne.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1331,
      "id": "morrow_after_the_golden_dusk",
      "name": "Morrow After the Golden Dusk",
      "description": "Saat berada dalam mode <color=#FFD780FF><b>Decoding</b></color>, kecepatan meningkatnya <color=#FFD780FF><b>Decoding Power</b></color> Fagio berkurang 50%, dan DMG reaksi Stellar-Conduct yang diakibatkan oleh seluruh Karakter dalam party meningkat 30%.",
      "level": 1
    },
    {
      "_id": 1332,
      "id": "an_heiress_gazed_into_the_lookingglass",
      "name": "An Heiress Gazed Into the Looking-Glass",
      "description": "<span style=\"color:#FFD780FF\">Radiance: Stellar-Conduct</span>: CRIT DMG sinar terkondensasi dari Charged Attack meningkat 40%. Dan setiap kali sinar terkondensasi ini ditembakkan, CRIT DMG yang diakibatkan semua sinar terkondensasi yang ditembakkan selama mode <color=#FFD780FF><b>Decoding</b></color> kali ini akan meningkat lagi sebesar 20%. Efek ini dapat ditumpuk sampai 3 lapis.",
      "level": 2
    },
    {
      "_id": 1333,
      "id": "refuse_the_wake_of_dusk_the_moonlit_yoke",
      "name": "Refuse the Wake of Dusk, the Moonlit Yoke",
      "description": "Meningkatkan 3 level Normal Attack <b><span style=\"color:#FFD780FF\">Formule Phenomenale: Self-Evident Proposition</span></b>.<br/>Maksimum: Lv. 15.",
      "level": 3
    },
    {
      "_id": 1334,
      "id": "in_knowledge_lies_the_worlds_true_ground",
      "name": "In Knowledge Lies the World's True Ground",
      "description": "Saat DMG reaksi Stellar-Conduct Sandrone mengenai musuh, ia akan memanggil 1 Prismatic Resonance Cannon tambahan untuk melancarkan serangan terkoordinasi yang mengakibatkan <span style=\"color:#99FFFFFF\">Cryo DMG</span> sebesar 125% ATK Sandrone kepada musuh. DMG ini dianggap sebagai DMG reaksi Stellar-Conduct dan efek ini dapat terpicu sekali setiap 4 detik.",
      "level": 4
    },
    {
      "_id": 1335,
      "id": "of_all_beside_she_takes_no_part",
      "name": "Of All Beside, She Takes No Part",
      "description": "Meningkatkan 3 level Elemental Burst <b><span style=\"color:#FFD780FF\">Formule Phenomenale: Q.E.D</span></b>.<br/>Maksimum: Lv. 15.",
      "level": 5
    },
    {
      "_id": 1336,
      "id": "narcissus_wakes_her_eyes_upon_the_dawn",
      "name": "Narcissus Wakes, Her Eyes Upon the Dawn",
      "description": "Dalam mode <color=#FFD780FF><b>Decoding</b></color>, saat Fagio menembakkan sinar terkondensasi untuk ketiga kalinya, serangan ini akan berubah menjadi <span style=\"color:#FFD780FF\">Condensed Cluster Beam</span> yang terus-menerus dan lebih kuat. Serangan ini akan mengakibatkan hingga 4 kali <span style=\"color:#99FFFFFF\">Cryo DMG Area</span> tambahan sebesar 100% ATK Sandrone di luar sinar terkondensasi dasar yang terus ditembakkan.<br/><span style=\"color:#FFD780FF\">Radiance: Stellar-Conduct</span>: Tembakan <span style=\"color:#FFD780FF\">Condensed Cluster Beam</span> berubah menjadi: mengakibatkan hingga 4 kali <span style=\"color:#99FFFFFF\">Cryo DMG Area</span> tambahan sebesar 80% ATK Sandrone, dan DMG ini dianggap sebagai DMG reaksi Stellar-Conduct.<br/>Selain itu, semua DMG reaksi Stellar-Conduct yang diakibatkan oleh Sandrone <b><span style=\"color:#FFD780FF\">bertumbuh</span></b> sebesar 20%.",
      "level": 6
    }
  ],
