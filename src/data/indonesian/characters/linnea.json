  "passives": [
    {
      "id": "field_observation_notes",
      "name": "Field Observation Notes",
      "description": "Saat Lumi berada di medan pertempuran, <span style=\"color:#FFE699FF\">Geo RES</span> musuh di sekitar Lumi berkurang 15%.<br/><br/><span style=\"color:#FFD780FF\">Moonsign: Ascendant Gleam</span>: Elemental Skill Linnea <color=#FFD780FF><b>Countermeasure: Lumi's Battle Cry!</b></color> dan Elemental Burst Linnea <color=#FFD780FF><b>Memo: Survival Guide in Extreme Conditions</b></color> akan diperkuat: Setelah memanggil Lumi ke medan pertempuran, <span style=\"color:#FFE699FF\">Geo RES</span> musuh di sekitar berkurang 15% lagi.",
      "level": 1
    },
    {
      "id": "universal_naturalist_archive",
      "name": "Universal Naturalist Archive",
      "description": "Linnea akan meningkatkan Elemental Mastery Karakter tertentu di dalam party berdasarkan Karakter aktif di dalam party. Jumlah peningkatannya adalah sebesar 5% DEF Linnea. Jika Karakter aktif dalam party sendiri adalah:<br/>·Karakter Moonsign: Meningkatkan Elemental Mastery Karakter ini.<br/>·Bukan Karakter Moonsign: Meningkatkan Elemental Mastery Linnea sendiri.",
      "level": 4
    },
    {
      "id": "moonsign_benediction_habitat_survey",
      "name": "Moonsign Benediction: Habitat Survey",
      "description": "Saat Karakter dalam party memicu reaksi Hydro Crystallize, reaksi tersebut akan dikonversi menjadi Lunar-Crystallize. Untuk setiap 100 poin DEF Linnea, DMG dasar reaksi Lunar-Crystallize meningkat 0,7%, dengan maksimum 14% peningkatan yang bisa didapatkan dengan cara ini.<br/><br/>Selain itu, saat Linnea ada di dalam party, <span style=\"color:#FFD780FF\">Moonsign</span> party akan meningkat 1 level.",
      "level": 0
    },
    {
      "id": "master_adventurer",
      "name": "Master Adventurer",
      "description": "Saat tidak dalam kondisi bertempur, waktu yang diperlukan untuk melakukan charge <span style=\"color:#FFD780FF\">Mode Membidik</span> Linnea akan berkurang drastis, dan anak panahnya akan dikonversi menjadi <span style=\"color:#FFD780FF\">Ultra Convenient Quick Arrow</span> yang khusus. Tembakan ini akan menghasilkan efek yang berbeda berdasarkan jenis target yang terkena:<br/>·Hewan tertentu: <span style=\"color:#FFD780FF\">Ultra Convenient Quick Arrow</span> akan dikonversi menjadi \"jaring\" khusus yang dapat menangkap bentuk ajaib hewan kecil dan menggunakannya sebagai media untuk mewujudkan kembali bentuk hewan tersebut. Jumlah \"jaring\" khusus yang dapat digunakan setiap minggu bersifat terbatas.<br/>·Bijih bebatuan yang dipakai untuk menempa: Linnea akan mengutus Lumi untuk menghancurkan bijih yang ditandai oleh <span style=\"color:#FFD780FF\">Ultra Convenient Quick Arrow</span> dan mengumpulkan bijih yang terjatuh. Jika Lumi tidak ada di medan, maka Linnea akan memanggil Lumi sejenak untuk membantunya mengumpulkan bijih.<br/><br/>DMG yang diakibatkan <span style=\"color:#FFD780FF\">Ultra Convenient Quick Arrow</span> terhadap musuh berkurang menjadi 20% dari DMG Charged Arrow awalnya. Selain itu, setelah menembakkan <span style=\"color:#FFD780FF\">Ultra Convenient Quick Arrow</span> beberapa kali sekaligus dalam waktu singkat, Linnea harus beristirahat sejenak untuk dapat menggunakannya kembali.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1301,
      "id": "provisional_classification",
      "name": "Provisional Classification",
      "description": "Saat melancarkan Elemental Skill <color=#FFD780FF><b>Countermeasure: Lumi's Battle Cry!</b></color>, atau saat memicu Moondrift Harmony, Linnea akan mendapatkan 6 lapis efek <span style=\"color:#FFD780FF\">Field Catalog</span> yang bertahan 10 detik dan dapat ditumpuk sampai 18 lapis. Saat Karakter sekitar di dalam party mengakibatkan DMG reaksi Lunar-Crystallize, akan mengonsumsi satu lapis efek Field Catalog untuk meningkatkan DMG yang diakibatkan sebesar 75% DEF Linnea.<br/>Selain itu, saat Lumi menggunakan <span style=\"color:#FFD780FF\">Million Ton Crush</span>-nya dalam bentuk <color=#FFD780FF><b>Ultimate Power Form</b></color>, Linnea dapat mengonsumsi maksimum 5 lapis Field Catalog untuk meningkatkan DMG yang diakibatkan sebesar 150% DEF Linnea setiap lapisnya.",
      "level": 1
    },
    {
      "_id": 1302,
      "id": "tidings_of_joy_and_sorrow",
      "name": "Tidings of Joy and Sorrow",
      "description": "Dalam 8 detik setelah memicu Moondrift Harmony, CRIT DMG seluruh Karakter <span style=\"color:#80C0FFFF\">Hydro</span> dan <span style=\"color:#FFE699FF\">Geo</span> di dalam party meningkat 40%. Selain itu CRIT DMG Lumi saat menggunakan <span style=\"color:#FFD780FF\">Million Ton Crush</span> dalam bentuk <color=#FFD780FF><b>Ultimate Power Form</b></color> akan meningkat 150% lagi.<br/><br/><span style=\"color:#FFD780FF\">Moonsign: Ascendant Gleam</span>: Saat Lumi menggunakan <span style=\"color:#FFD780FF\">Heavy Overdrive Hammer</span> dalam bentuk <color=#FFD780FF><b>Super Power Form</b></color>, atau saat menggunakan <span style=\"color:#FFD780FF\">Million Ton Crush</span> dalam bentuk Ultimate Power Form, maka akan terpicu satu kali Moondrift Harmony. Moondrift Harmony yang terpicu kali ini akan menganggap semua Karakter dalam party dengan jenis elemen <span style=\"color:#80C0FFFF\">Hydro</span> dan <span style=\"color:#FFE699FF\">Geo</span> telah mengaplikasikan elemen mereka ke dalam reaksinya.",
      "level": 2
    },
    {
      "_id": 1303,
      "id": "eventful_log_page",
      "name": "Eventful Log Page",
      "description": "Meningkatkan 3 level Elemental Skill <color=#FFD780FF><b>Countermeasure: Lumi's Battle Cry!</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 3
    },
    {
      "_id": 1304,
      "id": "expert_instinct",
      "name": "Expert Instinct",
      "description": "Setelah memicu Moondrift Harmony, DEF Linnea dan Karakter aktif sendiri dalam party meningkat 25% selama 5 detik. Saat Linnea ada di medan pertempuran, efek peningkatan DEF di atas dapat ditumpuk.",
      "level": 4
    },
    {
      "_id": 1305,
      "id": "fairylands_farewell_gift",
      "name": "Fairyland's Farewell Gift",
      "description": "Meningkatkan 3 level Elemental Burst <color=#FFD780FF><b>Memo: Survival Guide in Extreme Conditions</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 5
    },
    {
      "_id": 1306,
      "id": "golden_beagles_dream",
      "name": "Golden Beagle's Dream",
      "description": "Efek Konstelasi <span style=\"color:#FFD780FF\">Provisional Classification</span> diperkuat: Saat melancarkan Elemental Skill <color=#FFD780FF><b>Countermeasure: Lumi's Battle Cry!</b></color> atau saat memicu Moondrift Harmony, Linnea akan langsung mendapatkan efek <span style=\"color:#FFD780FF\">Field Catalog</span> dengan jumlah lapisan maksimum. Saat mengonsumsi <span style=\"color:#FFD780FF\">Field Catalog</span>, akan mengonsumsi lapisan sebanyak 2 kali lapisan awalnya untuk membuat efek peningkatan DMG-nya menjadi 150% dari awalnya.<br/><br/><span style=\"color:#FFD780FF\">Moonsign: Ascendant Gleam</span>: DMG yang diakibatkan reaksi Lunar-Crystallize Karakter party di sekitar <b><span style=\"color:#FFD780FF\">bertumbuh</span></b> 25%.",
      "level": 6
    }
  ],
