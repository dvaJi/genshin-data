  "passives": [
    {
      "id": "moratorium_on_questioning",
      "name": "Moratorium on Questioning",
      "description": "Dalam mode <b><span style=\"color:#FFD780FF\">Masterstroke</span> </b>, saat anggota party lain di sekitar mengakumulasi <b><span style=\"color:#FFD780FF\">Will to Win</span></b> untuk Lohen dengan cara mengakibatkan DMG, jika DMG yang diakibatkan kali ini tidak lebih rendah dari 3.000% Base ATK Lohen, maka akan mengakumulasi 60 poin <span style=\"color:#FFD780FF\">Will to Win</span> tambahan untuk Lohen.",
      "level": 1
    },
    {
      "id": "flippant_masterpiece",
      "name": "Flippant Masterpiece",
      "description": "Saat dalam mode <b><span style=\"color:#FFD780FF\">Masterstroke</span></b>, selama 8 detik setelah anggota party lain di sekitar memicu <span style=\"color:#99FFFFFF\">reaksi terkait Cryo</span> terhadap musuh, ATK Karakter tersebut meningkat 15% dan ATK Lohen meningkat 15%.",
      "level": 4
    },
    {
      "id": "when_the_mood_strikes",
      "name": "When the Mood Strikes",
      "description": "Setelah melancarkan Elemental Skill <span style=\"color:#FFD780FF\">Unforeseen Strike</span>, Lohen akan mendapatkan efek High Spirits selama 9 detik. High Spirits: Selama durasinya, level Elemental Skill <span style=\"color:#FFD780FF\">Unforeseen Strike</span> meningkat 1 level.<br/>Saat melancarkan Elemental Skill, jika level skill Normal Attack, Elemental Skill, atau Elemental Burst milik Karakter lain dalam party tidak lebih rendah dari level Elemental Skill Lohen, maka durasi efek High Spirits kali ini diperpanjang 6 detik lagi.<br/>Efek High Spirits bisa diperoleh sekali setiap 18 detik.",
      "level": 0
    }
  ],
  "constellations": [
    {
      "_id": 1291,
      "id": "o_breezes_that_so_oft_bear_sorrowful_lament",
      "name": "O Breezes, That So Oft Bear Sorrowful Lament",
      "description": "Batas maksimum <b><span style=\"color:#FFD780FF\">Will to Win</span></b> Lohen meningkat menjadi 300% dari batas awalnya.<br/>Selain itu, saat Lohen berada dalam mode <b><span style=\"color:#FFD780FF\">Masterstroke</span></b>, <span style=\"color:#FFD780FF\">Will to Win</span> yang diakumulasi anggota party lain di sekitar dengan cara mengakibatkan DMG akan bertambah menjadi 500% dari nilai awalnya.",
      "level": 1
    },
    {
      "_id": 1292,
      "id": "in_flight_i_strike_whatever_flies",
      "name": "In Flight, I Strike Whatever Flies",
      "description": "Saat berada dalam mode <b><span style=\"color:#FFD780FF\">Masterstroke</span></b>, selama 4 detik setelah Elemental Skill Khusus <b><span style=\"color:#FFD780FF\">Etched Into Bone and Soul</span></b> mengenai musuh atau melancarkan Elemental Burst <span style=\"color:#FFD780FF\">Manifest Judgment</span>, Lohen akan mendapatkan efek Evilsbane Blade: Saat Lohen berada dalam mode Masterstroke dan Normal Attack atau Charged Attack Lohen berikutnya mengenai musuh, maka ia akan mengakibatkan satu kali lagi serangan tambahan yang mengakibatkan <span style=\"color:#99FFFFFF\">Cryo DMG Area</span> sebesar 500% ATK Lohen dan meningkatkan 200 poin Elemental Mastery anggota party lain di sekitar selama 8 detik. Efek Evilsbane Blade dapat terpicu sekali setiap 4 detik.",
      "level": 2
    },
    {
      "_id": 1293,
      "id": "only_the_spear_that_wounds_can_heal",
      "name": "Only the Spear That Wounds Can Heal",
      "description": "Meningkatkan 3 level Elemental Skill <color=#FFD780FF><b>Unforeseen Strike</b></color>.<br/>Maksimum: Lv. 15.",
      "level": 3
    },
    {
      "_id": 1294,
      "id": "radiant_love_laughing_death",
      "name": "Radiant Love, Laughing Death",
      "description": "Saat Lohen melancarkan Elemental Burst <span style=\"color:#FFD780FF\">Manifest Judgment</span> dalam mode <b><span style=\"color:#FFD780FF\">Masterstroke</span></b>, ia akan langsung mengakumulasi <b><span style=\"color:#FFD780FF\">Will to Win</span></b> maksimum, lalu membuat Elemental Burst kali ini mendapatkan efek peningkatan DMG tertinggi.<br/><br/>Selain itu, saat Lohen berganti ke mode <span style=\"color:#FFD780FF\">Masterstroke</span>, jika Energy-nya:<br/>·Belum terisi penuh: Akan memulihkan 15 poin Energy Lohen.<br/>·Sudah terisi penuh: Melancarkan Elemental Burst <span style=\"color:#FFD780FF\">Manifest Judgment</span> dalam kurun waktu 15 detik akan memulihkan 15 poin Energy Lohen.",
      "level": 4
    },
    {
